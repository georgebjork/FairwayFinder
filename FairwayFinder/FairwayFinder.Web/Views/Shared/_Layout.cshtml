<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FairwayFinder.Web</title>
    <link rel="stylesheet" href="~/lib/bootstrap/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/lib/font-awesome/css/all.css" />
    <link rel="stylesheet" href="~/FairwayFinder.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <header class="container-fluid navbar sticky-top bg-dark flex-md-nowrap p-0 border-bottom">
      <div class="navbar-brand col-md-3 col-lg-2 px-3 text-white" style="display: flex; align-items: center;">
        <a href="#" class="text-white text-decoration-none ps-2"> <i class="fa-solid fa-golf-ball-tee pe-2"></i> FairwayFinder </a>
      </div>
    
      <ul class="navbar-nav flex-row">
        <li class="nav-item text-nowrap d-md-none">
          <button class="nav-link px-3 text-white" type="button" data-bs-toggle="offcanvas" data-bs-target="#sidebarMenu" aria-controls="sidebarMenu" aria-expanded="false" aria-label="Toggle navigation">
            <i class="fa-solid fa-bars"></i>
          </button>
        </li>
      </ul>
    </header>


<div class="container-fluid">
  <div class="row">
    <div class="sidebar fixed-sidebar border-end col-md-3 col-lg-2">
      <div class="offcanvas-md offcanvas-end" tabindex="-1" id="sidebarMenu" aria-labelledby="sidebarMenuLabel">
        <div class="offcanvas-header">
          <h5 class="offcanvas-title" id="sidebarMenuLabel">FairwayFinder <i class="fa-solid fa-golf-ball-tee ps-2"></i></h5>
          <button type="button" class="btn-close" data-bs-dismiss="offcanvas" data-bs-target="#sidebarMenu" aria-label="Close"></button>
        </div>
        <div class="offcanvas-body d-md-flex flex-column p-0 pt-md-3 overflow-y-auto">
          <ul class="nav nav-pills flex-column mb-auto px-2">
            <li class="nav-item">
              <a href="#" class="nav-link active" aria-current="page">
                <i class="fa-solid fa-house pe-2"></i>
                Home
              </a>
            </li>
            <li>
              <a href="#" class="nav-link text-white">
                <i class="fa-solid fa-house pe-2"></i>
                Dashboard
              </a>
            </li>
            <li>
              <a href="#" class="nav-link text-white">
                <i class="fa-solid fa-house pe-2"></i>
                Orders
              </a>
            </li>
            <li>
              <a href="#" class="nav-link text-white">
                <i class="fa-solid fa-house pe-2"></i>
                Products
              </a>
            </li>
            <li>
              <a href="#" class="nav-link text-white">
                <i class="fa-solid fa-house pe-2"></i>
                Customers
              </a>
            </li>
          </ul>
          <hr>
          <div class="dropdown px-2">
            <a href="#" class="d-flex align-items-center text-white text-decoration-none dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
              <img src="https://github.com/mdo.png" alt="" width="32" height="32" class="rounded-circle me-2">
              <strong>mdo</strong>
            </a>
            <ul class="dropdown-menu dropdown-menu-dark text-small shadow">
              <li><a class="dropdown-item" href="#">New project...</a></li>
              <li><a class="dropdown-item" href="#">Settings</a></li>
              <li><a class="dropdown-item" href="#">Profile</a></li>
              <li><hr class="dropdown-divider"></li>
              <li><a class="dropdown-item" href="#">Sign out</a></li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  
    <div class="col-md-9 ms-sm-auto col-lg-10 px-md-4" style="overflow-y: scroll; height: 95vh">
      <main role="main" class="pb-3">
        @RenderBody()
      </main>
    </div>
  </div>
</div>


    


    @*<footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2024 - FairwayFinder.Web - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>*@
    <script src="~/lib/htmx/htmx.js" asp-append-version="true"></script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
