@model ApplicationUser
@using Microsoft.AspNetCore.Identity
@using FairwayFinder.Core.Models

@inject UserManager<ApplicationUser> UserManager

<tr id="user-@Model.Id">
    <td>
        <div class="flex justify-start">
            @if (Model.IsAdmin){
            <button class="btn btn-secondary btn-xs pe-2" type="button" onclick="this.disabled=true;"
                    hx-trigger="click"
                    hx-post="/update-user-role/@Model.Id"
                    hx-swap="outerHTML"
                    hx-target="#user-@Model.Id">
                <i class="fa-solid fa-user pe-1"></i> User
            </button>
            }
            else{
            <button class="btn btn-success btn-xs pe-2" type="button" onclick="this.disabled=true;"
                    hx-trigger="click"
                    hx-post="/update-user-role/@Model.Id"
                    hx-swap="outerHTML"
                    hx-target="#user-@Model.Id">
                <i class="fa-solid fa-id-badge pe-1"></i> Admin
            </button>
            }
        </div>
    </td>
    <td>
        <div class="flex justify-end">
            @if (Model.EmailConfirmed){
                <div class="text-success"><i class="fa-regular fa-circle-check"></i></div>
            }
            else{
                <div class="text-error"><i class="fa-regular fa-circle-xmark"></i></div>
            }
        </div>
    </td>
    <td>@Model.Email</td>
    <td>
        <a class="link" asp-area="Profile" asp-controller="Profile" asp-action="ViewProfile" asp-route-userName="@Model.UserName" class="p-0">@Model.UserName</a>
    </td>
    <td>@(Model.FirstName + " " + Model.LastName)</td>
    <td>
        <div class="flex justify-end">
            
            <div class="pe-4">
                <a>
                    <i class="fa-solid fa-pen"></i>
                </a>
            </div>
            
            <div class="pe-2">
                @if (Model.LockoutEnd is not null && Model.LockoutEnd > DateTime.UtcNow){
                    <button type="button" onclick="this.disabled=true;"
                            hx-trigger="click"
                            hx-post="/enable-user/@Model.Id"
                            hx-swap="outerHTML"
                            hx-target="#user-@Model.Id">

                        <i class="fa-solid fa-user-check"></i>
                    </button>
                }
                else{
                    <button type="button" onclick="this.disabled=true;"
                            hx-trigger="click"
                            hx-post="/remove-user/@Model.Id"
                            hx-swap="outerHTML"
                            hx-target="#user-@Model.Id">

                        <i class="fa-solid fa-trash text-error"></i>
                    </button>
                }

            </div>
        </div>
    </td>
</tr>