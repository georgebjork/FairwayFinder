@model ApplicationUser
@using Microsoft.AspNetCore.Identity
@using FairwayFinder.Core.Models

@inject UserManager<ApplicationUser> UserManager

<tr id="user-@Model.Id">
    <td>
        <div class="flex justify-between align-middle">
            <div>
                @Model.Id
            </div>
            @if (Model.EmailConfirmed)
            {
                <div class="text-success"><i class="fa-regular fa-circle-check"></i></div>
            }
            else
            {
                <div class="text-error"><i class="fa-regular fa-circle-xmark"></i></div>
            }
        </div>
    </td>
    <td>@Model.Email</td>
    <td>
        <a class="link" asp-area="Profile" asp-controller="Profile" asp-action="ViewProfile" asp-route-userName="@Model.UserName" class="p-0">@Model.UserName</a>
    </td>
    <td>@(Model.FirstName + " " + Model.LastName)</td>
    <td>
        <div class="flex justify-evenly">
            @if (Model.IsAdmin)
            {
                <button class="btn btn-success btn-xs pe-2" type="button" onclick="this.innerText='Applying role...'; this.disabled=true;"
                        hx-trigger="click"
                        hx-post="/update-user-role/@Model.Id"
                        hx-swap="outerHTML"
                        hx-target="#user-@Model.Id">
                    Revoke Admin
                </button>
            }
            else
            {
                <button class="btn btn-success btn-xs pe-2" type="button" onclick="this.innerText='Applying role...'; this.disabled=true;"
                        hx-trigger="click"
                        hx-post="/update-user-role/@Model.Id"
                        hx-swap="outerHTML"
                        hx-target="#user-@Model.Id">
                    Promote Admin
                </button>
            }

            <button class="btn btn-error btn-xs" type="button" onclick="this.innerText='Removing...'; this.disabled=true;"
                    hx-trigger="click"
                    hx-post="/remove-user/@Model.Id"
                    hx-swap="outerHTML"
                    hx-target="#user-@Model.Id">
                
                <i class="fa-solid fa-trash pe2 "></i> Remove User
            </button>
        </div>
    </td>
</tr>