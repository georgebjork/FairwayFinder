@using Microsoft.AspNetCore.Mvc.TagHelpers
@model FairwayFinder.Core.Features.CourseManagement.Models.FormModels.CourseFormModel


<div id="course-form">
    <div class="grid grid-cols-12 gap-4 mt-3">
        <div class="col-span-12">
            @await Html.PartialAsync("_MessageHtmxPartial")
        </div>
    </div>


    <div class="grid grid-cols-12 gap-4 mt-3">
        <div class="md:col-span-12 col-span-12">
            <div class="label">
                <label asp-for="Name" class="label-text"></label>
            </div>
            <input asp-for="Name" type="text" class="input input-bordered w-full gap-2" />
            <span asp-validation-for="Name" class="text-error"></span>
        </div>
    </div>


    <div class="grid grid-cols-12 gap-4 mt-3">
        <div class="md:col-span-12 col-span-12">
            <div class="label">
                <label asp-for="Address" class="label-text"></label>
            </div>
            <input asp-for="Address" type="text" class="input input-bordered w-full gap-2" />
            <span asp-validation-for="Address" class="text-error"></span>
        </div>
    </div>


    <div class="grid grid-cols-12 gap-4 mt-3">
        <div class="md:col-span-12 col-span-12">
            <div class="label">
                <label asp-for="PhoneNumber" class="label-text"></label>
            </div>
            <input asp-for="PhoneNumber" type="text" class="input input-bordered w-full gap-2" />
            <span asp-validation-for="PhoneNumber" class="text-error"></span>
        </div>
    </div>
</div>
