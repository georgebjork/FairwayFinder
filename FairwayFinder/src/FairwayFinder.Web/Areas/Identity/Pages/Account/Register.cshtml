@page "/register/{invitation?}"
@model RegisterModel
@{
    ViewData["Title"] = "Register";
}

<div class="sm:mx-auto w-full sm:max-w-sm">
    <h2 class="text-center text-2xl font-bold">Sign up</h2>
</div>

<div class="mt-10 sm:mx-auto w-full sm:max-w-sm">
    <form class="space-y-6" id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
        <div class="grid grid-cols-12 gap-2 lg:gap-4">
            <div class="col-span-6">
                <label asp-for="Input.FirstName" class="input input-bordered flex items-center gap-2 w-full">
                    <input asp-for="Input.FirstName" type="text" class="grow" placeholder="First Name"/>
                </label>
                <span asp-validation-for="Input.FirstName" class="text-error"></span>
            </div>
            
            <div class="col-span-6">
                <label asp-for="Input.LastName" class="input input-bordered flex items-center gap-2 w-full">
                    <input asp-for="Input.LastName" type="text" class="grow" placeholder="Last Name"/>
                </label>
                <span asp-validation-for="Input.LastName" class="text-error"></span>
            </div>
        </div>
        
        <div>
            <label asp-for="Input.Email" class="input input-bordered flex items-center gap-2 w-full">
                <input asp-for="Input.Email" type="email" class="grow" placeholder="Email"/>
            </label>
            <span asp-validation-for="Input.Email" class="text-error"></span>
        </div>
        
        <div class="grid grid-cols-12 gap-2 lg:gap-4">
            <div class="col-span-6">
                <label asp-for="Input.Password" class="input input-bordered flex items-center gap-2 w-full">
                    <input asp-for="Input.Password" type="password" class="grow" placeholder="Password"/>
                </label>
                <span asp-validation-for="Input.Password" class="text-error"></span>
            </div>
                    
            <div class="col-span-6">
                <label asp-for="Input.ConfirmPassword" class="input input-bordered flex items-center gap-2 w-full">
                    <input asp-for="Input.ConfirmPassword" type="password" class="grow" placeholder="Confirm Password"/>
                </label>
                <span asp-validation-for="Input.ConfirmPassword" class="text-error"></span>
            </div>
        </div>
        
        <div>
            <button id="register-submit" type="submit" class="w-full btn btn-primary">Register <i class="fa-solid fa-right-to-bracket ps-2"></i></button>
        </div>
    </form>
</div>


<div class="row d-flex justify-content-center align-items-center pt-5">
    <div class="col-xl-9 col-12">
        <form >
            
            <input type="hidden" asp-for="Input.InvitationCode" value="@Model.Input.InvitationCode"/>
            
            <h2>Register your account.</h2>
            <hr/>
            
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            
            <div class="row">
                <div class="col-xl-6 col-12">
                    <div class="form-floating mb-3">
                        <input asp-for="Input.FirstName" class="form-control" autocomplete="username" aria-required="true"/>
                        <label asp-for="Input.FirstName"></label>
                        <span asp-validation-for="Input.FirstName" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-xl-6 col-12">
                    <div class="form-floating mb-3">
                        <input asp-for="Input.LastName" class="form-control" autocomplete="username" aria-required="true"/>
                        <label asp-for="Input.LastName"></label>
                        <span asp-validation-for="Input.LastName" class="text-danger"></span>
                    </div>
                </div>
            </div>
            
            <div class="row">
                <div class="col-12">
                    <div class="form-floating mb-3">
                        <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true"/>
                        <label asp-for="Input.Email"></label>
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>
                </div>
            </div>
            
            <div class="row">
                <div class="col-xl-6 col-12">
                    <div class="form-floating mb-3">
                        <input asp-for="Input.Password" class="form-control" autocomplete="new-password" aria-required="true"/>
                        <label asp-for="Input.Password"></label>
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-xl-6 col-12">
                    <div class="form-floating mb-3">
                        <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" aria-required="true"/>
                        <label asp-for="Input.ConfirmPassword"></label>
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                    </div>
                </div>
            </div>
            
           
            <button id="registerSubmit" type="submit" class="w-100 btn btn-lg btn-outline-primary">Register <i class="fa-solid fa-right-to-bracket ps-2"></i></button>
        </form>
    </div>
</div>