@page "/register/{invitation?}"
@model RegisterModel
@{
    ViewData["Title"] = "Register";
}

<div class="row d-flex justify-content-center align-items-center pt-5">
    <div class="col-xl-9 col-12">
        <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
            
            <input type="hidden" asp-for="Input.InvitationCode" value="@Model.Input.InvitationCode"/>
            
            <h2>Register your account.</h2>
            <hr/>
            
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            
            <div class="row">
                <div class="col-xl-6 col-12">
                    <div class="form-floating mb-3">
                        <input asp-for="Input.FirstName" class="form-control" autocomplete="username" aria-required="true"/>
                        <label asp-for="Input.FirstName"></label>
                        <span asp-validation-for="Input.FirstName" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-xl-6 col-12">
                    <div class="form-floating mb-3">
                        <input asp-for="Input.LastName" class="form-control" autocomplete="username" aria-required="true"/>
                        <label asp-for="Input.LastName"></label>
                        <span asp-validation-for="Input.LastName" class="text-danger"></span>
                    </div>
                </div>
            </div>
            
            <div class="row">
                <div class="col-12">
                    <div class="form-floating mb-3">
                        <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true"/>
                        <label asp-for="Input.Email"></label>
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>
                </div>
            </div>
            
            <div class="row">
                <div class="col-xl-6 col-12">
                    <div class="form-floating mb-3">
                        <input asp-for="Input.Password" class="form-control" autocomplete="new-password" aria-required="true"/>
                        <label asp-for="Input.Password"></label>
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-xl-6 col-12">
                    <div class="form-floating mb-3">
                        <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" aria-required="true"/>
                        <label asp-for="Input.ConfirmPassword"></label>
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                    </div>
                </div>
            </div>
            
           
            <button id="registerSubmit" type="submit" class="w-100 btn btn-lg btn-outline-primary">Register <i class="fa-solid fa-right-to-bracket ps-2"></i></button>
        </form>
    </div>
</div>