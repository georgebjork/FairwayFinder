@page
@model ResetPasswordModel
@{
    ViewData["Title"] = "Reset password";
}

<div class="sm:mx-auto sm:w-full sm:max-w-sm">
    <h2 class="text-center text-2xl font-bold">Reset Your Password</h2>
</div>

<div class="mt-10 sm:mx-auto sm:w-full sm:max-w-sm md:max-w-md lg:max-w-lg">
    <form method="post" class="space-y-6">
        <div asp-validation-summary="ModelOnly" class="text-error" role="alert"></div>
        <input asp-for="Input.Code" type="hidden"/>
        
        <div>
            <label asp-for="Input.Email" class="input input-bordered flex items-center gap-2 w-full">
                <input asp-for="Input.Email" type="text" class="grow" placeholder="Email"/>
            </label>
            <span asp-validation-for="Input.Email" class="text-error"></span>
        </div>
        <div>
            <label asp-for="Input.Password" class="input input-bordered flex items-center gap-2 w-full">
                <input asp-for="Input.Password" type="password" class="grow" placeholder="New Password"/>
            </label>
            <span asp-validation-for="Input.Password" class="text-error"></span>
        </div>
        <div>
            <label asp-for="Input.ConfirmPassword" class="input input-bordered flex items-center gap-2 w-full">
                <input asp-for="Input.ConfirmPassword" type="password" class="grow" placeholder="Confirm Password"/>
            </label>
            <span asp-validation-for="Input.ConfirmPassword" class="text-error"></span>
        </div>
        
        <button type="submit" class="btn-block btn btn-primary">Reset</button>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
