@{
	var info = (string?)TempData["info_message"];
	var warning = (string?)TempData["warning_message"];
	var success = (string?)TempData["success_message"];
	var error = (string?)TempData["error_message"];

	var infoPersistent = (string?)TempData["info_message_persistent"];
	var warningPersistent = (string?)TempData["warning_message_persistent"];
	var errorPersistent = (string?)TempData["error_message_persistent"];
	
	
}
<div class="my-2">
	@if (!string.IsNullOrWhiteSpace(info)) {
		<div id='info-message' class="alert alert-info" role="alert">
			<span>
				<i class="bx bx-xs bx-detail me-2"></i>
				@info
			</span>
		</div>
		<script type='text/javascript'>
		document.addEventListener('DOMContentLoaded', function() {
			$("#info-message").fadeTo(4000, 500).slideUp(500, function(){
				$("#info-message").alert('close');
			});
		}, false);
	</script>
	}
	@if (!string.IsNullOrWhiteSpace(success)) {
		<div id='success-message' class="alert alert-success" role="alert">
			<span>
				<i class="bx bx-xs bx-detail me-2"></i>
				@success
			</span>
		</div>
		<script type='text/javascript'>
		document.addEventListener('DOMContentLoaded',function() {
			$("#success-message").fadeTo(4000, 500).slideUp(500, function(){
				$("#success-message").alert('close');
			});
		},false);
	</script>
	}
	@if (!string.IsNullOrWhiteSpace(warning)) {
		<div id='warning-message' class="alert alert-warning" role="alert">
			<span>
				<i class="bx bx-xs bx-detail me-2"></i>
				@warning
			</span>
		</div>
		<script type='text/javascript'>
		document.addEventListener('DOMContentLoaded',function() {
			$("#warning-message").fadeTo(4000, 500).slideUp(500, function(){
				$("#warning-message").alert('close');
			});
		},false);
	</script>
	}
	@if (!string.IsNullOrWhiteSpace(error)) {
		<div id='error-message' class="alert alert-danger" role="alert">
			<span>
				<i class="bx bx-xs bx-detail me-2"></i>
				@error
			</span>
		</div>
		<script type='text/javascript'>
		document.addEventListener('DOMContentLoaded',function() {
			$("#error-message").fadeTo(4000, 500).slideUp(500, function(){
				$("#error-message").alert('close');
			});
		},false);
	</script>
	}


	@if (!string.IsNullOrWhiteSpace(infoPersistent))
	{
		<div id='info-message-persistent' class="alert alert-info d-flex align-items-center" role="alert">
			<span>
				<i class="bx bx-xs bx-detail me-2"></i>
				@infoPersistent
			</span>
		</div>
	}
	@if (!string.IsNullOrWhiteSpace(warningPersistent))
	{
		<div id='warning-message-persistent' class="alert alert-warning d-flex align-items-center" role="alert">
			<span>
				<i class="bx bx-xs bx-detail me-2"></i>
				@warningPersistent
			</span>
		</div>
	}

	@if (!string.IsNullOrWhiteSpace(errorPersistent))
	{
		<div id='error-message-persistent' class="alert alert-danger d-flex align-items-center" role="alert">
			<span>
				<i class="bx bx-xs bx-detail me-2"></i>
				@errorPersistent
			</span>
		</div>
	}
</div>
