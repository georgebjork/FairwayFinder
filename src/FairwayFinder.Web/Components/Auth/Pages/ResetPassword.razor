@layout AuthenticationLayout
@page "/reset-password"
@attribute [ExcludeFromInteractiveRouting]
@attribute [AllowAnonymous]

@using System.ComponentModel.DataAnnotations
@using System.Text
@using FairwayFinder.Identity
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.WebUtilities
@inject UserManager<ApplicationUser> UserManager
@inject IdentityRedirectManager RedirectManager

<RadzenStack AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Center" Style="min-height: 100%;">
    <RadzenStack Gap="2rem" Style="width: 100%; max-width: 420px;">

        <RadzenStack AlignItems="AlignItems.Center" Gap="1rem">
            <RadzenText TextStyle="TextStyle.H3" Style="margin: 0;">FairwayFinder</RadzenText>
        </RadzenStack>

        <RadzenCard>
            <EditForm Model="Input" method="post" OnValidSubmit="OnValidSubmitAsync" FormName="reset-password">
                <DataAnnotationsValidator />
                <RadzenStack Gap="1.5rem">
                    <RadzenStack Gap="0.5rem">
                        <RadzenText TextStyle="TextStyle.H5" Style="margin: 0;">Reset your password</RadzenText>
                        <RadzenText TextStyle="TextStyle.Body2">
                            Enter your new password below.
                        </RadzenText>
                    </RadzenStack>

                    @if (!string.IsNullOrEmpty(_errorMessage))
                    {
                        <RadzenAlert AlertStyle="AlertStyle.Danger" Variant="Variant.Flat" Shade="Shade.Lighter">
                            @_errorMessage
                        </RadzenAlert>
                    }

                    <input type="hidden" name="Input.Email" value="@Input!.Email" />
                    <input type="hidden" name="Input.Token" value="@Input!.Token" />

                    <RadzenFormField Text="New password" Variant="Variant.Outlined">
                        <InputText type="password" @bind-Value="Input!.Password" class="rz-textbox" autocomplete="new-password" aria-required="true" placeholder="Enter new password" />
                        <ValidationMessage For="() => Input.Password" />
                    </RadzenFormField>

                    <RadzenFormField Text="Confirm password" Variant="Variant.Outlined">
                        <InputText type="password" @bind-Value="Input!.ConfirmPassword" class="rz-textbox" autocomplete="new-password" aria-required="true" placeholder="Confirm new password" />
                        <ValidationMessage For="() => Input.ConfirmPassword" />
                    </RadzenFormField>

                    <RadzenButton
                        ButtonType="ButtonType.Submit"
                        Text="Reset Password"
                        Style="width: 100%;"
                        ButtonStyle="ButtonStyle.Primary"
                        Variant="Variant.Filled"
                        Size="ButtonSize.Medium" />
                </RadzenStack>
            </EditForm>
        </RadzenCard>
    </RadzenStack>
</RadzenStack>

@code {
    private string? _errorMessage;

    [SupplyParameterFromForm]
    private InputModel? Input { get; set; }

    [SupplyParameterFromQuery]
    private string? Email { get; set; }

    [SupplyParameterFromQuery]
    private string? Token { get; set; }

    protected override void OnInitialized()
    {
        if (Input is null)
        {
            Input = new()
            {
                Email = Email ?? "",
                Token = Token ?? ""
            };
        }
    }

    private async Task OnValidSubmitAsync()
    {
        var user = await UserManager.FindByEmailAsync(Input!.Email);
        if (user is null)
        {
            // Don't reveal that the user does not exist
            RedirectManager.RedirectTo("/login");
            return;
        }

        var decodedToken = Encoding.UTF8.GetString(WebEncoders.Base64UrlDecode(Input.Token));
        var result = await UserManager.ResetPasswordAsync(user, decodedToken, Input.Password);

        if (result.Succeeded)
        {
            RedirectManager.RedirectTo("/login");
            return;
        }

        _errorMessage = string.Join(" ", result.Errors.Select(e => e.Description));
    }

    private sealed class InputModel
    {
        public string Email { get; set; } = "";

        public string Token { get; set; } = "";

        [Required]
        [StringLength(100, ErrorMessage = "The {0} must be at least {2} and at max {1} characters long.", MinimumLength = 6)]
        [DataType(DataType.Password)]
        public string Password { get; set; } = "";

        [DataType(DataType.Password)]
        [Compare("Password", ErrorMessage = "The password and confirmation password do not match.")]
        public string ConfirmPassword { get; set; } = "";
    }
}
