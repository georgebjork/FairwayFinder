@page "/admin"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Admin")]
@using FairwayFinder.Web.Components.Pages.Admin.Components
@inject BreadcrumbState BreadcrumbState

<PageTitle>Administration</PageTitle>

<RadzenStack Gap="1.5rem" Style="max-width: 1200px;" class="rz-mx-auto rz-p-4">
    <RadzenTabs>
        <Tabs>
            <RadzenTabsItem Text="TGTR" Icon="sync">
                <TgtrAdminTab />
            </RadzenTabsItem>
            <RadzenTabsItem Text="Users" Icon="people">
                <UsersTab />
            </RadzenTabsItem>
            <RadzenTabsItem Text="Connections" Icon="cable">
                <WebSocketConnectionsTab />
            </RadzenTabsItem>
            <RadzenTabsItem Text="Agent Testing" Icon="smart_toy">
                <AgentTestingTab />
            </RadzenTabsItem>
        </Tabs>
    </RadzenTabs>
</RadzenStack>

@code {
    protected override void OnInitialized()
    {
        BreadcrumbState.Set(
            new BreadcrumbItem("Home", "/"),
            new BreadcrumbItem("Administration")
        );
    }
}
