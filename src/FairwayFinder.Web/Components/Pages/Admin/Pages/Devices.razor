@page "/admin/devices"
@rendermode InteractiveServer
@layout AdminLayout
@attribute [Authorize(Roles = "Admin")]
@using FairwayFinder.Features.Services.Admin
@using FairwayFinder.Web.Components.Shared.Layout.Breadcrumb
@inject AdminDeviceService AdminDeviceService
@inject BreadcrumbState BreadcrumbState

<PageTitle>Registered Devices</PageTitle>

<RadzenStack Gap="1.5rem">
    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Center" Wrap="FlexWrap.Wrap" Gap="1rem">
        <RadzenText TextStyle="TextStyle.H4" class="rz-m-0">Registered Devices</RadzenText>
        <RadzenButton Text="Refresh" Icon="refresh" ButtonStyle="ButtonStyle.Light" Variant="Variant.Outlined"
                      Size="ButtonSize.Small" Click="LoadDevicesAsync" Disabled="_loading" />
    </RadzenStack>

    @if (_loading)
    {
        <RadzenStack AlignItems="AlignItems.Center" class="rz-p-8">
            <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
        </RadzenStack>
    }
    else if (_devices.Count == 0)
    {
        <RadzenAlert AlertStyle="AlertStyle.Info" Shade="Shade.Lighter" AllowClose="false">
            No devices have been registered yet.
        </RadzenAlert>
    }
    else
    {
        <RadzenStack Gap="1rem">
            <RadzenTextBox Placeholder="Search by device, platform, or user..." Value="@_searchQuery"
                           @oninput="OnSearchChanged" Style="width: 100%; max-width: 420px;" />

            <RadzenDataGrid TItem="AdminDeviceListItemDto" Data="FilteredDevices"
                            AllowFiltering="true" FilterMode="FilterMode.Advanced"
                            AllowSorting="true" AllowPaging="true" PageSize="15"
                            PagerHorizontalAlign="HorizontalAlign.Right"
                            ShowPagingSummary="true"
                            PagingSummaryFormat="Displaying page {0} of {1} (total {2} devices)"
                            EmptyText="No devices match your search.">
                <Columns>
                    <RadzenDataGridColumn TItem="AdminDeviceListItemDto" Title="Device">
                        <Template Context="device">
                            @(string.IsNullOrWhiteSpace(device.DeviceName) ? "Unnamed device" : device.DeviceName)
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="AdminDeviceListItemDto" Property="Platform" Title="Platform" Width="110px">
                        <Template Context="device">
                            <RadzenBadge Text="@device.Platform" BadgeStyle="BadgeStyle.Info" Shade="Shade.Lighter" />
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="AdminDeviceListItemDto" Property="PlayerName" Title="Registered To" Width="220px" />
                    <RadzenDataGridColumn TItem="AdminDeviceListItemDto" Property="PlayerEmail" Title="Email" />
                    <RadzenDataGridColumn TItem="AdminDeviceListItemDto" Title="Status" Width="100px" Sortable="false" Filterable="false" TextAlign="TextAlign.Center">
                        <Template Context="device">
                            @if (device.IsActive)
                            {
                                <RadzenIcon Icon="check_circle" Style="color: var(--rz-success); font-size: 1.25rem;" Title="Active" />
                            }
                            else
                            {
                                <RadzenIcon Icon="cancel" Style="color: var(--rz-text-disabled-color); font-size: 1.25rem;" Title="Inactive" />
                            }
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="AdminDeviceListItemDto" Property="LastSeenAt" Title="Last Seen" Width="170px" FormatString="{0:yyyy-MM-dd HH:mm}" />
                    <RadzenDataGridColumn TItem="AdminDeviceListItemDto" Property="CreatedAt" Title="Registered" Width="150px" FormatString="{0:MMM d, yyyy}" />
                </Columns>
            </RadzenDataGrid>
        </RadzenStack>
    }
</RadzenStack>

@code {
    private List<AdminDeviceListItemDto> _devices = new();
    private bool _loading = true;
    private string _searchQuery = string.Empty;

    private IEnumerable<AdminDeviceListItemDto> FilteredDevices => string.IsNullOrWhiteSpace(_searchQuery)
        ? _devices
        : _devices.Where(d =>
            (d.DeviceName?.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase) ?? false) ||
            d.Platform.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase) ||
            d.PlayerName.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase) ||
            d.PlayerEmail.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase));

    protected override void OnInitialized()
    {
        BreadcrumbState.Set(
            new BreadcrumbItem("Home", "/"),
            new BreadcrumbItem("Administration", "/admin"),
            new BreadcrumbItem("Devices")
        );
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadDevicesAsync();
    }

    private async Task LoadDevicesAsync()
    {
        _loading = true;
        _devices = await AdminDeviceService.GetAllDevicesAsync();
        _loading = false;
    }

    private void OnSearchChanged(ChangeEventArgs e)
    {
        _searchQuery = e.Value?.ToString() ?? string.Empty;
    }
}
