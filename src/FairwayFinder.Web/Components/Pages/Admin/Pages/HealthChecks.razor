@page "/admin/health"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Admin")]
@using Microsoft.Extensions.Diagnostics.HealthChecks
@using System.Reflection
@inject HealthCheckService HealthCheckService
@inject BreadcrumbState BreadcrumbState
@inject ILogger<HealthChecks> Logger

<PageTitle>Health Checks</PageTitle>

<RadzenStack Gap="1.5rem" class="rz-mx-auto rz-p-4" Style="max-width: 1200px;">

    @* ── System Health Section ── *@
    <RadzenCard>
        <RadzenStack Gap="1rem">
            <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Center">
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                    <RadzenIcon Icon="monitor_heart" Style="color: var(--rz-text-secondary-color);" />
                    <RadzenText TextStyle="TextStyle.H6" class="rz-m-0">System Health</RadzenText>
                </RadzenStack>
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.75rem">
                    @if (_lastChecked.HasValue)
                    {
                        <RadzenText TextStyle="TextStyle.Caption" style="color: var(--rz-text-secondary-color);">
                            Last checked: @_lastChecked.Value.ToLocalTime().ToString("HH:mm:ss")
                        </RadzenText>
                    }
                    <RadzenButton Text="Refresh" Icon="refresh" ButtonStyle="ButtonStyle.Light"
                                  Size="ButtonSize.Small" Click="RefreshHealthChecks"
                                  IsBusy="_isLoadingHealth" />
                </RadzenStack>
            </RadzenStack>

            @if (_isLoadingHealth)
            {
                <RadzenStack JustifyContent="JustifyContent.Center" AlignItems="AlignItems.Center" class="rz-p-4" Gap="0.5rem">
                    <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate"
                                              Size="ProgressBarCircularSize.Medium" />
                    <RadzenText TextStyle="TextStyle.Body2" style="color: var(--rz-text-secondary-color);">
                        Running health checks...
                    </RadzenText>
                </RadzenStack>
            }
            else if (_healthReport is not null)
            {
                @* Overall status banner *@
                <RadzenAlert AlertStyle="@GetOverallAlertStyle(_healthReport.Status)"
                             Shade="Shade.Lighter" AllowClose="false" Size="AlertSize.Small">
                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center"
                                 JustifyContent="JustifyContent.SpaceBetween" Wrap="FlexWrap.Wrap" Gap="0.5rem">
                        <RadzenText TextStyle="TextStyle.Body1" class="rz-m-0">
                                <strong>Overall Status:</strong> @_healthReport.Status
                            </RadzenText>
                        <RadzenText TextStyle="TextStyle.Body2" class="rz-m-0">
                            Total duration: @_healthReport.TotalDuration.TotalMilliseconds.ToString("F0") ms
                        </RadzenText>
                    </RadzenStack>
                </RadzenAlert>

                @* Per-check grid *@
                <RadzenDataGrid TItem="HealthEntry" Data="_healthEntries"
                                AllowSorting="false" AllowPaging="false"
                                GridLines="DataGridGridLines.Horizontal"
                                Density="Density.Default">
                    <Columns>
                        <RadzenDataGridColumn TItem="HealthEntry" Title="Service" Width="260px">
                            <Template Context="entry">
                                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                                    <RadzenIcon Icon="@GetHealthIcon(entry.Status)"
                                                style="@GetHealthIconStyle(entry.Status)" />
                                    <RadzenIcon Icon="@GetServiceIcon(entry.Name)"
                                                style="color: var(--rz-text-secondary-color); font-size: 1rem;" />
                                    <RadzenText TextStyle="TextStyle.Body2" class="rz-m-0">@entry.Name</RadzenText>
                                </RadzenStack>
                            </Template>
                        </RadzenDataGridColumn>

                        <RadzenDataGridColumn TItem="HealthEntry" Title="Status" Width="120px">
                            <Template Context="entry">
                                <RadzenBadge Text="@entry.Status.ToString()"
                                             BadgeStyle="@GetBadgeStyle(entry.Status)"
                                             Shade="Shade.Lighter" />
                            </Template>
                        </RadzenDataGridColumn>

                        <RadzenDataGridColumn TItem="HealthEntry" Title="Response Time" Width="160px">
                            <Template Context="entry">
                                <RadzenStack Gap="0.25rem">
                                    <RadzenText TextStyle="TextStyle.Body2" class="rz-m-0">
                                        @entry.Duration.TotalMilliseconds.ToString("F1") ms
                                    </RadzenText>
                                    <RadzenProgressBar Value="@Math.Min(entry.Duration.TotalMilliseconds, 1000)"
                                                       Max="1000"
                                                       ProgressBarStyle="@GetProgressBarStyle(entry.Status)"
                                                       ShowValue="false"
                                                       Style="height: 4px;" />
                                </RadzenStack>
                            </Template>
                        </RadzenDataGridColumn>

                        <RadzenDataGridColumn TItem="HealthEntry" Title="Description">
                            <Template Context="entry">
                                @if (entry.Exception is not null)
                                {
                                    <RadzenStack Gap="0.25rem">
                                        <RadzenText TextStyle="TextStyle.Body2" class="rz-m-0"
                                                    style="color: var(--rz-danger);">
                                            @entry.Exception.Message
                                        </RadzenText>
                                        @if (!string.IsNullOrWhiteSpace(entry.Description))
                                        {
                                            <RadzenText TextStyle="TextStyle.Caption" class="rz-m-0"
                                                        style="color: var(--rz-text-secondary-color);">
                                                @entry.Description
                                            </RadzenText>
                                        }
                                    </RadzenStack>
                                }
                                else
                                {
                                    <RadzenText TextStyle="TextStyle.Body2" class="rz-m-0"
                                                style="color: var(--rz-text-secondary-color);">
                                        @(string.IsNullOrWhiteSpace(entry.Description) ? "—" : entry.Description)
                                    </RadzenText>
                                }
                            </Template>
                        </RadzenDataGridColumn>

                        <RadzenDataGridColumn TItem="HealthEntry" Title="Tags" Width="180px">
                            <Template Context="entry">
                                <RadzenStack Orientation="Orientation.Horizontal" Wrap="FlexWrap.Wrap" Gap="0.25rem">
                                    @foreach (var tag in entry.Tags)
                                    {
                                        <RadzenBadge Text="@tag" BadgeStyle="BadgeStyle.Light"
                                                     Shade="Shade.Default" />
                                    }
                                </RadzenStack>
                            </Template>
                        </RadzenDataGridColumn>
                    </Columns>
                </RadzenDataGrid>
            }
            else if (_loadError is not null)
            {
                <RadzenAlert AlertStyle="AlertStyle.Danger" Shade="Shade.Lighter" AllowClose="false">
                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                        <RadzenIcon Icon="error" />
                        <RadzenText TextStyle="TextStyle.Body2" class="rz-m-0">@_loadError</RadzenText>
                    </RadzenStack>
                </RadzenAlert>
            }
        </RadzenStack>
    </RadzenCard>

    @* ── System Information Section ── *@
    <RadzenCard>
        <RadzenStack Gap="1rem">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                <RadzenIcon Icon="info" Style="color: var(--rz-text-secondary-color);" />
                <RadzenText TextStyle="TextStyle.H6" class="rz-m-0">System Information</RadzenText>
            </RadzenStack>

            <RadzenRow RowGap="1rem" Gap="1rem">
                <RadzenColumn Size="6" SizeMD="3">
                    <RadzenStack Gap="0.25rem">
                        <RadzenText TextStyle="TextStyle.Caption"
                                    style="color: var(--rz-text-secondary-color);" class="rz-m-0">
                            App Version
                        </RadzenText>
                        <RadzenText TextStyle="TextStyle.Body2" class="rz-m-0">
                            @(Assembly.GetExecutingAssembly().GetName().Version?.ToString() ?? "—")
                        </RadzenText>
                    </RadzenStack>
                </RadzenColumn>
                <RadzenColumn Size="6" SizeMD="3">
                    <RadzenStack Gap="0.25rem">
                        <RadzenText TextStyle="TextStyle.Caption"
                                    style="color: var(--rz-text-secondary-color);" class="rz-m-0">
                            Environment
                        </RadzenText>
                        <RadzenText TextStyle="TextStyle.Body2" class="rz-m-0">
                            @(Environment.GetEnvironmentVariable("ASPNETCORE_ENVIRONMENT") ?? "Production")
                        </RadzenText>
                    </RadzenStack>
                </RadzenColumn>
                <RadzenColumn Size="6" SizeMD="3">
                    <RadzenStack Gap="0.25rem">
                        <RadzenText TextStyle="TextStyle.Caption"
                                    style="color: var(--rz-text-secondary-color);" class="rz-m-0">
                            .NET Version
                        </RadzenText>
                        <RadzenText TextStyle="TextStyle.Body2" class="rz-m-0">
                            @Environment.Version.ToString()
                        </RadzenText>
                    </RadzenStack>
                </RadzenColumn>
                <RadzenColumn Size="6" SizeMD="3">
                    <RadzenStack Gap="0.25rem">
                        <RadzenText TextStyle="TextStyle.Caption"
                                    style="color: var(--rz-text-secondary-color);" class="rz-m-0">
                            Machine Name
                        </RadzenText>
                        <RadzenText TextStyle="TextStyle.Body2" class="rz-m-0">
                            @Environment.MachineName
                        </RadzenText>
                    </RadzenStack>
                </RadzenColumn>
            </RadzenRow>

            <RadzenRow RowGap="1rem" Gap="1rem">
                <RadzenColumn Size="6" SizeMD="3">
                    <RadzenStack Gap="0.25rem">
                        <RadzenText TextStyle="TextStyle.Caption"
                                    style="color: var(--rz-text-secondary-color);" class="rz-m-0">
                            OS
                        </RadzenText>
                        <RadzenText TextStyle="TextStyle.Body2" class="rz-m-0">
                            @Environment.OSVersion.Platform.ToString()
                        </RadzenText>
                    </RadzenStack>
                </RadzenColumn>
                <RadzenColumn Size="6" SizeMD="3">
                    <RadzenStack Gap="0.25rem">
                        <RadzenText TextStyle="TextStyle.Caption"
                                    style="color: var(--rz-text-secondary-color);" class="rz-m-0">
                            Process ID
                        </RadzenText>
                        <RadzenText TextStyle="TextStyle.Body2" class="rz-m-0">
                            @Environment.ProcessId.ToString()
                        </RadzenText>
                    </RadzenStack>
                </RadzenColumn>
                <RadzenColumn Size="6" SizeMD="3">
                    <RadzenStack Gap="0.25rem">
                        <RadzenText TextStyle="TextStyle.Caption"
                                    style="color: var(--rz-text-secondary-color);" class="rz-m-0">
                            Working Set
                        </RadzenText>
                        <RadzenText TextStyle="TextStyle.Body2" class="rz-m-0">
                            @FormatBytes(Environment.WorkingSet)
                        </RadzenText>
                    </RadzenStack>
                </RadzenColumn>
                <RadzenColumn Size="6" SizeMD="3">
                    <RadzenStack Gap="0.25rem">
                        <RadzenText TextStyle="TextStyle.Caption"
                                    style="color: var(--rz-text-secondary-color);" class="rz-m-0">
                            Processor Count
                        </RadzenText>
                        <RadzenText TextStyle="TextStyle.Body2" class="rz-m-0">
                            @Environment.ProcessorCount.ToString()
                        </RadzenText>
                    </RadzenStack>
                </RadzenColumn>
            </RadzenRow>

            <RadzenRow RowGap="1rem" Gap="1rem">
                <RadzenColumn Size="6" SizeMD="3">
                    <RadzenStack Gap="0.25rem">
                        <RadzenText TextStyle="TextStyle.Caption"
                                    style="color: var(--rz-text-secondary-color);" class="rz-m-0">
                            Server Time (UTC)
                        </RadzenText>
                        <RadzenText TextStyle="TextStyle.Body2" class="rz-m-0">
                            @DateTime.UtcNow.ToString("yyyy-MM-dd HH:mm:ss")
                        </RadzenText>
                    </RadzenStack>
                </RadzenColumn>
            </RadzenRow>
        </RadzenStack>
    </RadzenCard>

</RadzenStack>

@code {
    private bool _isLoadingHealth = true;
    private HealthReport? _healthReport;
    private List<HealthEntry> _healthEntries = [];
    private string? _loadError;
    private DateTime? _lastChecked;

    protected override void OnInitialized()
    {
        BreadcrumbState.Set(
            new BreadcrumbItem("Home", "/"),
            new BreadcrumbItem("Health Checks")
        );
    }

    protected override async Task OnInitializedAsync()
    {
        await RefreshHealthChecks();
    }

    private async Task RefreshHealthChecks()
    {
        _isLoadingHealth = true;
        _loadError = null;
        StateHasChanged();

        try
        {
            _healthReport = await HealthCheckService.CheckHealthAsync();
            _lastChecked = DateTime.UtcNow;
            _healthEntries = _healthReport.Entries
                .Select(kvp => new HealthEntry
                {
                    Name = kvp.Key,
                    Status = kvp.Value.Status,
                    Duration = kvp.Value.Duration,
                    Description = kvp.Value.Description,
                    Exception = kvp.Value.Exception,
                    Tags = kvp.Value.Tags.ToList()
                })
                .OrderBy(e => e.Name)
                .ToList();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to retrieve health checks");
            _loadError = $"Failed to run health checks: {ex.Message}";
        }
        finally
        {
            _isLoadingHealth = false;
        }
    }

    // ── Status helpers ──

    private static AlertStyle GetOverallAlertStyle(HealthStatus status) => status switch
    {
        HealthStatus.Healthy => AlertStyle.Success,
        HealthStatus.Degraded => AlertStyle.Warning,
        _ => AlertStyle.Danger
    };

    private static string GetOverallIcon(HealthStatus status) => status switch
    {
        HealthStatus.Healthy => "check_circle",
        HealthStatus.Degraded => "warning",
        _ => "error"
    };

    private static string GetHealthIcon(HealthStatus status) => status switch
    {
        HealthStatus.Healthy => "check_circle",
        HealthStatus.Degraded => "warning",
        _ => "error"
    };

    private static string GetHealthIconStyle(HealthStatus status) => status switch
    {
        HealthStatus.Healthy => "color: var(--rz-success);",
        HealthStatus.Degraded => "color: var(--rz-warning);",
        _ => "color: var(--rz-danger);"
    };

    private static BadgeStyle GetBadgeStyle(HealthStatus status) => status switch
    {
        HealthStatus.Healthy => BadgeStyle.Success,
        HealthStatus.Degraded => BadgeStyle.Warning,
        _ => BadgeStyle.Danger
    };

    private static ProgressBarStyle GetProgressBarStyle(HealthStatus status) => status switch
    {
        HealthStatus.Healthy => ProgressBarStyle.Success,
        HealthStatus.Degraded => ProgressBarStyle.Warning,
        _ => ProgressBarStyle.Danger
    };

    private static string GetServiceIcon(string name)
    {
        var n = name.ToLowerInvariant();
        if (n.Contains("sql") || n.Contains("postgres") || n.Contains("database") || n.Contains("db"))
            return "storage";
        if (n.Contains("redis") || n.Contains("cache"))
            return "memory";
        if (n.Contains("email") || n.Contains("mail") || n.Contains("smtp"))
            return "email";
        if (n.Contains("blob") || n.Contains("storage") || n.Contains("s3"))
            return "cloud";
        if (n.Contains("queue") || n.Contains("bus") || n.Contains("rabbit"))
            return "sync_alt";
        if (n.Contains("api") || n.Contains("http"))
            return "api";
        return "settings";
    }

    private static string FormatBytes(long bytes)
    {
        string[] sizes = ["B", "KB", "MB", "GB", "TB"];
        int order = 0;
        double size = bytes;
        while (size >= 1024 && order < sizes.Length - 1) { order++; size /= 1024; }
        return $"{size:0.##} {sizes[order]}";
    }

    private class HealthEntry
    {
        public string Name { get; set; } = "";
        public HealthStatus Status { get; set; }
        public TimeSpan Duration { get; set; }
        public string? Description { get; set; }
        public Exception? Exception { get; set; }
        public List<string> Tags { get; set; } = [];
    }
}
