<RadzenStack Gap="1rem">
    <RadzenText TextStyle="TextStyle.Body1">
        Are you sure you want to delete <strong>@EntityName</strong>? This action cannot be undone.
    </RadzenText>

    @if (!string.IsNullOrEmpty(WarningMessage))
    {
        <RadzenAlert AlertStyle="AlertStyle.Warning" Shade="Shade.Lighter" AllowClose="false" Size="AlertSize.Small">
            <RadzenText TextStyle="TextStyle.Body2" class="rz-m-0">@WarningMessage</RadzenText>
        </RadzenAlert>
    }

    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="0.5rem">
        <RadzenButton Text="Cancel" ButtonStyle="ButtonStyle.Light"
                      Click="@(() => DialogService.Close(false))" />
        <RadzenButton Text="Delete" Icon="delete" ButtonStyle="ButtonStyle.Danger"
                      Click="@(() => DialogService.Close(true))" />
    </RadzenStack>
</RadzenStack>

@code {
    [Inject] public DialogService DialogService { get; set; } = default!;

    [Parameter] public string EntityName { get; set; } = string.Empty;
    [Parameter] public string? WarningMessage { get; set; }
}
