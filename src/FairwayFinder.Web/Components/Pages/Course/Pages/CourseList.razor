@page "/courses"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Admin")]
@using System.Security.Claims
@using FairwayFinder.Features.Data
@using FairwayFinder.Features.Services.Interfaces
@using FairwayFinder.Web.Components.Pages.Course.Dialogs
@inject ICourseService CourseService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager
@inject NotificationService NotificationService
@inject DialogService DialogService
@inject BreadcrumbState BreadcrumbState

<PageTitle>Course Management</PageTitle>

<RadzenStack Gap="1.5rem" Style="max-width: 1100px;" class="rz-mx-auto rz-p-4">
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
            <RadzenIcon Icon="golf_course" Style="font-size: 1.75rem;" />
            <RadzenText TextStyle="TextStyle.H4" class="rz-m-0">Course Management</RadzenText>
        </RadzenStack>
        <RadzenButton Text="Add Course" Icon="add" ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.Small"
                      Click="OnAddCourseClicked" />
    </RadzenStack>

    @if (_loading)
    {
        <RadzenStack AlignItems="AlignItems.Center" class="rz-p-8">
            <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
        </RadzenStack>
    }
    else if (_courses.Count == 0)
    {
        <RadzenAlert AlertStyle="AlertStyle.Info" Shade="Shade.Lighter" AllowClose="false">
            No courses found. Click "Add Course" to create one.
        </RadzenAlert>
    }
    else
    {
        <RadzenCard>
            <RadzenStack Gap="1rem">
                <RadzenTextBox Placeholder="Search courses by name..." Value="@_searchText"
                               @oninput="@OnSearchInput" Style="width: 100%;" />

                <RadzenDataGrid Data="@FilteredCourses"
                                TItem="CourseListItem"
                                AllowFiltering="true"
                                FilterMode="FilterMode.Advanced"
                                AllowSorting="true"
                                AllowPaging="true"
                                PageSize="10"
                                PagerHorizontalAlign="HorizontalAlign.Right"
                                ShowPagingSummary="true"
                                PagingSummaryFormat="Displaying page {0} of {1} (total {2} courses)"
                                Style="cursor: pointer;"
                                @bind-Value="@_selectedCourse"
                                RowClick="@OnRowClick">
                    <Columns>
                        <RadzenDataGridColumn TItem="CourseListItem" Property="CourseName" Title="Course" />
                        <RadzenDataGridColumn TItem="CourseListItem" Property="Address" Title="Address" />
                        <RadzenDataGridColumn TItem="CourseListItem" Property="PhoneNumber" Title="Phone" Width="160px" />
                        <RadzenDataGridColumn TItem="CourseListItem" Property="TeeboxCount" Title="Teeboxes" Width="100px" TextAlign="TextAlign.Center" />
                    </Columns>
                </RadzenDataGrid>
            </RadzenStack>
        </RadzenCard>
    }
</RadzenStack>

@code {
    private List<CourseListItem> _courses = new();
    private bool _loading = true;
    private string _currentUserId = string.Empty;
    private string _searchText = string.Empty;
    private IList<CourseListItem> _selectedCourse = [];

    private IEnumerable<CourseListItem> FilteredCourses =>
        string.IsNullOrWhiteSpace(_searchText)
            ? _courses
            : _courses.Where(c => c.CourseName.Contains(_searchText, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        BreadcrumbState.Set(
            new BreadcrumbItem("Home", "/"),
            new BreadcrumbItem("Courses")
        );

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        _currentUserId = authState.User.FindFirstValue(ClaimTypes.NameIdentifier) ?? string.Empty;
        await LoadCoursesAsync();
    }

    private async Task LoadCoursesAsync()
    {
        _loading = true;
        _courses = await CourseService.GetAllCoursesAsync();
        _loading = false;
    }

    private void OnSearchInput(ChangeEventArgs args)
    {
        _searchText = args.Value?.ToString() ?? string.Empty;
    }

    private void OnRowClick(DataGridRowMouseEventArgs<CourseListItem> args)
    {
        if (args.Data is not null)
        {
            NavigationManager.NavigateTo($"/courses/{args.Data.CourseId}");
        }
    }

    private async Task OnAddCourseClicked()
    {
        var result = await DialogService.OpenAsync<AddEditCourseDialog>("Add Course",
            new Dictionary<string, object>(),
            new DialogOptions
            {
                Width = "500px",
                CloseDialogOnOverlayClick = false,
                CloseDialogOnEsc = true
            });

        if (result is SaveCourseRequest request)
        {
            try
            {
                var courseId = await CourseService.CreateCourseAsync(request, _currentUserId);
                NotificationService.Notify(new NotificationMessage
                {
                    Severity = NotificationSeverity.Success,
                    Summary = "Course Created",
                    Detail = $"{request.CourseName} has been created.",
                    Duration = 4000
                });
                NavigationManager.NavigateTo($"/courses/{courseId}");
            }
            catch (Exception ex)
            {
                NotificationService.Notify(new NotificationMessage
                {
                    Severity = NotificationSeverity.Error,
                    Summary = "Failed to Create Course",
                    Detail = ex.Message,
                    Duration = 6000
                });
            }
        }
    }
}
