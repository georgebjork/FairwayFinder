@using FairwayFinder.Features.Data
@using FairwayFinder.Features.Enums
@using FairwayFinder.Features.Services.Interfaces
@using FairwayFinder.Web.Components.Pages.Home.Dialogs
@using Microsoft.AspNetCore.WebUtilities
@inject IStatsService StatsService
@inject IRoundService RoundService
@inject IProfileService ProfileService
@inject NavigationManager NavigationManager
@inject DialogService DialogService
@inject NotificationService NotificationService
@inject IJSRuntime JSRuntime

<RadzenStack Gap="1.5rem">
    <!-- Optional Header -->
    @if (!string.IsNullOrEmpty(HeaderText))
    {
        <RadzenStack Gap="0.25rem">
            <RadzenText TextStyle="TextStyle.H3" class="rz-m-0">@HeaderText</RadzenText>
        </RadzenStack>
    }

    <!-- Filters -->
    <StatsFilterBar @bind-StartDate="_startDate"
                    @bind-EndDate="_endDate"
                    HasActiveFilters="_hasActiveFilters"
                    OnClearFilters="ClearFilters"
                    OnFilterChanged="OnFilterChanged">
        <AdditionalFilters>
            <RadzenStack Gap="0.25rem">
                <RadzenText TextStyle="TextStyle.Caption" style="color: var(--rz-text-secondary-color);">Round Type</RadzenText>
                <RadzenDropDown TValue="string"
                                Data="@_roundTypeOptions"
                                TextProperty="Text"
                                ValueProperty="Value"
                                @bind-Value="_selectedRoundType"
                                Style="width: 140px;"
                                Change="@OnFilterChanged" />
            </RadzenStack>
            <RadzenStack Gap="0.25rem">
                <RadzenText TextStyle="TextStyle.Caption" style="color: var(--rz-text-secondary-color);">Course</RadzenText>
                <RadzenDropDown TValue="long?"
                                Data="@_courseOptions"
                                TextProperty="CourseName"
                                ValueProperty="CourseId"
                                @bind-Value="_selectedCourseId"
                                Placeholder="All Courses"
                                AllowClear="true"
                                AllowFiltering="true"
                                Style="width: 200px;"
                                Change="@OnFilterChanged" />
            </RadzenStack>
            <RadzenStack Gap="0.25rem">
                <RadzenText TextStyle="TextStyle.Caption" style="color: var(--rz-text-secondary-color);">Golfer Level</RadzenText>
                <RadzenDropDown TValue="BaselineLevel"
                                Data="@_baselineLevelOptions"
                                TextProperty="Text"
                                ValueProperty="Value"
                                @bind-Value="_sgBaselineLevel"
                                Style="width: 150px;"
                                Change="@OnFilterChanged" />
            </RadzenStack>
        </AdditionalFilters>
        <TrailingContent>
            @if (!string.IsNullOrEmpty(ShareUrl))
            {
                <RadzenButton Text="Share" Icon="share"
                              ButtonStyle="ButtonStyle.Light" Variant="Variant.Outlined"
                              Size="ButtonSize.Medium"
                              Click="CopyShareLink"
                              Style="margin-left: auto;"/>
            }
        </TrailingContent>
    </StatsFilterBar>

    <!-- Stats Cards -->
    @if (_loading)
    {
        <RadzenStack Orientation="Orientation.Horizontal" Gap="1rem" Wrap="FlexWrap.Wrap">
            <RadzenCard class="stats-card-loading">
                <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
            </RadzenCard>
            <RadzenCard class="stats-card-loading">
                <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
            </RadzenCard>
            <RadzenCard class="stats-card-loading">
                <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
            </RadzenCard>
        </RadzenStack>
    }
    else if (_stats is not null)
    {
        <RadzenStack Orientation="Orientation.Horizontal" Gap="1rem" Wrap="FlexWrap.Wrap">
            <FairwayFinderStatsCard
                Label="Rounds Played"
                Value="@_stats.TotalRounds.ToString()" />

            @if (_stats.Scoring.Average18HoleScore.HasValue)
            {
                <FairwayFinderStatsCard
                    Label="Avg Score (18)"
                    Value="@(_stats.Scoring.Average18HoleScore?.ToString("F1") ?? "-")"
                    SubText="@(_stats.Scoring.Rounds18Hole + " rounds")">
                    @if (_stats.Scoring.Average18HoleScoreTrend.HasValue)
                    {
                        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.25rem" JustifyContent="JustifyContent.Center">
                            @if (_stats.Scoring.Average18HoleScoreTrend < 0) {
                                <RadzenIcon Icon="trending_down" IconStyle="IconStyle.Success"/>
                                <RadzenText TextStyle="TextStyle.Caption">
                                    @_stats.Scoring.Average18HoleScoreTrend.Value
                                </RadzenText>
                            }
                            else
                            {
                                <RadzenIcon Icon="trending_up" IconStyle="IconStyle.Danger"/>
                                <RadzenText TextStyle="TextStyle.Caption">
                                    + @_stats.Scoring.Average18HoleScoreTrend.Value.ToString("F1")
                                </RadzenText>
                            }
                        </RadzenStack>
                    }
                </FairwayFinderStatsCard>
            }

            @if (_stats.Scoring.Average9HoleScore.HasValue)
            {
                <FairwayFinderStatsCard
                    Label="Avg Score (9)"
                    Value="@(_stats.Scoring.Average9HoleScore?.ToString("F1") ?? "-")"
                    SubText="@(_stats.Scoring.Rounds9Hole + " rounds")">
                    @if (_stats.Scoring.Average9HoleScoreTrend.HasValue)
                    {
                        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.25rem" JustifyContent="JustifyContent.Center">
                            @if (_stats.Scoring.Average9HoleScoreTrend < 0) {
                                <RadzenIcon Icon="trending_down" IconStyle="IconStyle.Success"/>
                                <RadzenText TextStyle="TextStyle.Caption">
                                    @_stats.Scoring.Average9HoleScoreTrend.Value
                                </RadzenText>
                            }
                            else
                            {
                                <RadzenIcon Icon="trending_up" IconStyle="IconStyle.Danger"/>
                                <RadzenText TextStyle="TextStyle.Caption">
                                    + @_stats.Scoring.Average9HoleScoreTrend.Value.ToString("F1")
                                </RadzenText>
                            }
                        </RadzenStack>
                    }
                </FairwayFinderStatsCard>
            }

            @if (_stats.Scoring.Best18HoleRound is not null)
            {
                <FairwayFinderStatsCard
                    Label="Best Round (18)"
                    Value="@_stats.Scoring.Best18HoleRound.Score.ToString()"
                    SubText="@_stats.Scoring.Best18HoleRound.CourseName"
                    OnClick="NavigateToBestFullRound"/>
            }

            @if (_stats.Scoring.Best9HoleRound is not null)
            {
                <FairwayFinderStatsCard
                    Label="Best Round (9)"
                    Value="@_stats.Scoring.Best9HoleRound.Score.ToString()"
                    SubText="@_stats.Scoring.Best9HoleRound.CourseName"
                    OnClick="NavigateToNineHoleRound"/>
            }

        </RadzenStack>

        <BallStrikingCards Stats="@_stats.BallStriking" ShowTrendDialogs="@ShowTrendDialogs" />
        <ShortGameCards Stats="@_stats.ShortGame" ShowTrendDialogs="@ShowTrendDialogs" />

        <ParTypeCards Stats="@_stats.ParTypeScoring" />
    }

    <!-- Strokes Gained Section -->
    @if (_stats?.StrokesGained.Summary is not null)
    {
        <RadzenStack Gap="1rem">
            <RadzenText TextStyle="TextStyle.H5" class="rz-m-0">Strokes Gained</RadzenText>

            <StrokesGainedCards Summary="@_stats.StrokesGained.Summary" OnCardClicked="@OnSgCardClicked" />

            <RadzenCard>
                <RadzenText TextStyle="TextStyle.H5" class="rz-mb-4">SG Trend</RadzenText>
                <StrokesGainedTrendChart
                    TotalTrend="@_stats.StrokesGained.TotalTrend"
                    PuttingTrend="@_stats.StrokesGained.PuttingTrend"
                    TeeToGreenTrend="@_stats.StrokesGained.TeeToGreenTrend" />
            </RadzenCard>
        </RadzenStack>
    }

    <!-- Charts Row -->
    <RadzenRow Gap="1rem">
        <RadzenColumn Size="12" SizeLG="7">
            <RadzenCard Style="height: 100%;">
                <RadzenText TextStyle="TextStyle.H5" class="rz-mb-4">Score Trend</RadzenText>
                <FairwayFinderScoreTrendChart TrendData18Hole="@_stats?.Scoring.ScoreTrend18Hole" TrendData9Hole="@_stats?.Scoring.ScoreTrend9Hole" />
            </RadzenCard>
        </RadzenColumn>
        <RadzenColumn Size="12" SizeLG="5">
            <RadzenCard Style="height: 100%;">
                <RadzenText TextStyle="TextStyle.H5" class="rz-mb-4">Scoring Distribution</RadzenText>
                <FairwayFinderScoringDistributionChart Distribution="@_stats?.ScoringDistribution" />
            </RadzenCard>
        </RadzenColumn>
    </RadzenRow>

    <!-- Recent Rounds & Most Played Courses -->
    <RadzenRow Gap="1rem">
        <RadzenColumn Size="12" SizeLG="8">
            <RadzenCard Style="height: 100%;">
                <RadzenText TextStyle="TextStyle.H5" class="rz-mb-4">Recent Rounds</RadzenText>
                <FairwayFinderRoundsList Rounds="@_rounds" RoundUrlPrefix="@RoundUrlPrefix" />
            </RadzenCard>
        </RadzenColumn>
        <RadzenColumn Size="12" SizeLG="4">
            <RadzenCard Style="height: 100%;">
                <RadzenText TextStyle="TextStyle.H5" class="rz-mb-4">Most Played Courses</RadzenText>
                <FairwayFinderMostPlayedCourses Courses="@_stats?.MostPlayedCourses" CourseUrlPrefix="@RoundUrlPrefix" />
            </RadzenCard>
        </RadzenColumn>
    </RadzenRow>
</RadzenStack>

<style>
    .stats-card-loading {
        min-width: 150px;
        min-height: 100px;
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
    }
</style>

@code {
    /// <summary>
    /// The user ID whose stats to load and display.
    /// </summary>
    [Parameter, EditorRequired]
    public string UserId { get; set; } = null!;

    /// <summary>
    /// The base URL path used when persisting filter query parameters.
    /// e.g. "/" for the owner dashboard, "/profile/{guid}" for a public profile.
    /// </summary>
    [Parameter, EditorRequired]
    public string BasePath { get; set; } = "/";

    /// <summary>
    /// Optional prefix prepended to round navigation URLs.
    /// When null, rounds navigate to "/round/{id}".
    /// When set (e.g. "/profile/{guid}"), rounds navigate to "{prefix}/round/{id}".
    /// </summary>
    [Parameter]
    public string? RoundUrlPrefix { get; set; }

    /// <summary>
    /// Whether clicking advanced stats cards (FIR, GIR, Putts) opens trend dialogs.
    /// true for the owner's dashboard, false for public viewers.
    /// </summary>
    [Parameter]
    public bool ShowTrendDialogs { get; set; } = true;

    /// <summary>
    /// Optional header text displayed above the dashboard (e.g. a user's display name).
    /// </summary>
    [Parameter]
    public string? HeaderText { get; set; }

    /// <summary>
    /// Optional shareable URL. When set, a Share button appears in the filter bar.
    /// </summary>
    [Parameter]
    public string? ShareUrl { get; set; }

    private UserStatsResponse? _stats;
    private List<RoundResponse> _rounds = new();
    private bool _loading = true;

    // Filter state
    private string _selectedRoundType = "all";
    private long? _selectedCourseId;
    private DateOnly? _startDate;
    private DateOnly? _endDate;
    private BaselineLevel _sgBaselineLevel = BaselineLevel.Scratch;
    private List<CourseOption> _courseOptions = new();

    private static readonly IReadOnlyList<BaselineLevelOption> _baselineLevelOptions =
        BaselineLevelExtensions.AllInDisplayOrder
            .Select(l => new BaselineLevelOption(l, l.DisplayName()))
            .ToList();

    private record BaselineLevelOption(BaselineLevel Value, string Text);

    private bool _hasActiveFilters => _selectedRoundType != "all" || _selectedCourseId.HasValue || _startDate.HasValue || _endDate.HasValue;

    private readonly List<object> _roundTypeOptions = new()
    {
        new { Text = "All Rounds", Value = "all" },
        new { Text = "18 Hole", Value = "18" },
        new { Text = "9 Hole", Value = "9" }
    };

    protected override async Task OnInitializedAsync()
    {
        _courseOptions = await StatsService.GetUserCoursesAsync(UserId);
        // Seed the golfer-level selector from the user's saved default (owner or profile owner).
        var profile = await ProfileService.GetOrCreateProfileAsync(UserId);
        _sgBaselineLevel = profile.SgBaselineLevel;
        ParseQueryParameters();
        await LoadStats();
        _loading = false;
    }

    private void ParseQueryParameters()
    {
        var uri = new Uri(NavigationManager.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query);

        if (query.TryGetValue("type", out var typeValue))
        {
            var type = typeValue.ToString();
            if (type == "18" || type == "9")
            {
                _selectedRoundType = type;
            }
        }

        if (query.TryGetValue("course", out var courseValue) && long.TryParse(courseValue.ToString(), out var courseId))
        {
            _selectedCourseId = courseId;
        }

        if (query.TryGetValue("from", out var fromValue) && DateOnly.TryParse(fromValue.ToString(), out var startDate))
        {
            _startDate = startDate;
        }

        if (query.TryGetValue("to", out var toValue) && DateOnly.TryParse(toValue.ToString(), out var endDate))
        {
            _endDate = endDate;
        }
    }

    private void UpdateUrl()
    {
        var queryParams = new Dictionary<string, string?>();

        if (_selectedRoundType != "all")
        {
            queryParams["type"] = _selectedRoundType;
        }

        if (_selectedCourseId.HasValue)
        {
            queryParams["course"] = _selectedCourseId.Value.ToString();
        }

        if (_startDate.HasValue)
        {
            queryParams["from"] = _startDate.Value.ToString("yyyy-MM-dd");
        }

        if (_endDate.HasValue)
        {
            queryParams["to"] = _endDate.Value.ToString("yyyy-MM-dd");
        }

        var basePath = BasePath.TrimEnd('/');
        if (string.IsNullOrEmpty(basePath)) basePath = "/";

        var newUrl = queryParams.Count > 0
            ? QueryHelpers.AddQueryString(basePath, queryParams!)
            : basePath;

        NavigationManager.NavigateTo(newUrl, replace: true);
    }

    private StatsFilter BuildFilter()
    {
        return new StatsFilter
        {
            FullRoundOnly = _selectedRoundType switch
            {
                "18" => true,
                "9" => false,
                _ => null
            },
            CourseId = _selectedCourseId,
            StartDate = _startDate,
            EndDate = _endDate
        };
    }

    private async Task LoadStats()
    {
        var filter = BuildFilter();
        var statsTask = StatsService.GetUserStatsAsync(UserId, filter, level: _sgBaselineLevel);
        var roundsTask = RoundService.GetRoundsByUserIdAsync(UserId, filter);
        await Task.WhenAll(statsTask, roundsTask);
        _stats = statsTask.Result;
        _rounds = roundsTask.Result;
    }

    private async Task OnFilterChanged()
    {
        _loading = true;
        StateHasChanged();

        UpdateUrl();
        await LoadStats();

        _loading = false;
    }

    private async Task ClearFilters()
    {
        _selectedRoundType = "all";
        _selectedCourseId = null;
        _startDate = null;
        _endDate = null;

        await OnFilterChanged();
    }

    private string BuildRoundUrl(long roundId)
    {
        var prefix = string.IsNullOrEmpty(RoundUrlPrefix) ? "" : RoundUrlPrefix.TrimEnd('/');
        return $"{prefix}/round/{roundId}";
    }

    private void NavigateToBestFullRound()
    {
        if (_stats?.Scoring.Best18HoleRound is not null)
        {
            NavigationManager.NavigateTo(BuildRoundUrl(_stats.Scoring.Best18HoleRound.RoundId));
        }
    }

    private void NavigateToNineHoleRound()
    {
        if (_stats?.Scoring.Best9HoleRound is not null)
        {
            NavigationManager.NavigateTo(BuildRoundUrl(_stats.Scoring.Best9HoleRound.RoundId));
        }
    }

    private async Task CopyShareLink()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", ShareUrl);
            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Success,
                Summary = "Copied!",
                Detail = "Link copied to clipboard.",
                Duration = 2000
            });
        }
        catch
        {
            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Warning,
                Summary = "Copy Failed",
                Detail = "Please copy the link manually.",
                Duration = 3000
            });
        }
    }

    private async Task OnSgCardClicked(string category)
    {
        if (!ShowTrendDialogs) return;

        switch (category)
        {
            case "Total":
                await ShowSgTotalTrendDialog();
                break;
            case "Putting":
                await ShowSgPuttingTrendDialog();
                break;
            case "OTT":
            case "Approach":
            case "ARG":
                // OTT, Approach, and ARG share the Tee to Green trend
                await ShowSgTeeToGreenTrendDialog();
                break;
        }
    }

    private async Task ShowSgTotalTrendDialog()
    {
        if (_stats?.StrokesGained.TotalTrend is null || _stats.StrokesGained.TotalTrend.Count < 2) return;

        await DialogService.OpenAsync<SgTotalTrendDialog>("SG:Total Trend",
            new Dictionary<string, object>
            {
                { "TrendData", _stats.StrokesGained.TotalTrend }
            },
            new DialogOptions
            {
                Width = "700px",
                CloseDialogOnOverlayClick = true,
                CloseDialogOnEsc = true
            });
    }

    private async Task ShowSgPuttingTrendDialog()
    {
        if (_stats?.StrokesGained.PuttingTrend is null || _stats.StrokesGained.PuttingTrend.Count < 2) return;

        await DialogService.OpenAsync<SgPuttingTrendDialog>("SG:Putting Trend",
            new Dictionary<string, object>
            {
                { "TrendData", _stats.StrokesGained.PuttingTrend }
            },
            new DialogOptions
            {
                Width = "700px",
                CloseDialogOnOverlayClick = true,
                CloseDialogOnEsc = true
            });
    }

    private async Task ShowSgTeeToGreenTrendDialog()
    {
        if (_stats?.StrokesGained.TeeToGreenTrend is null || _stats.StrokesGained.TeeToGreenTrend.Count < 2) return;

        await DialogService.OpenAsync<SgTeeToGreenTrendDialog>("SG:Tee to Green Trend",
            new Dictionary<string, object>
            {
                { "TrendData", _stats.StrokesGained.TeeToGreenTrend }
            },
            new DialogOptions
            {
                Width = "700px",
                CloseDialogOnOverlayClick = true,
                CloseDialogOnEsc = true
            });
    }
}
