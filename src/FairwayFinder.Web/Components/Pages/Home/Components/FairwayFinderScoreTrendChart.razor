@using FairwayFinder.Features.Data
@using FairwayFinder.Features.Helpers
@inject NavigationManager NavigationManager

@{
    var hasData18 = TrendData18Hole is not null && TrendData18Hole.Count >= 2;
    var hasData9 = TrendData9Hole is not null && TrendData9Hole.Count >= 2;
    var showToggle = hasData18 && hasData9;
    var hasAnyData = hasData18 || hasData9;
}

@if (!hasAnyData)
{
    <RadzenStack AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Center" Style="min-height: 300px;">
        <RadzenText TextStyle="TextStyle.Body2" style="color: var(--rz-text-secondary-color);">
            Not enough rounds to show trend. Play more rounds to see your score trend!
        </RadzenText>
    </RadzenStack>
}
else
{
    @if (showToggle)
    {
        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" class="rz-mb-2">
            <RadzenSelectBar @bind-Value="_selectedRoundType" TValue="string" Size="ButtonSize.Medium" Change="@OnRoundTypeChanged">
                <Items>
                    <RadzenSelectBarItem Text="18 Hole" Value="@("18")" />
                    <RadzenSelectBarItem Text="9 Hole" Value="@("9")" />
                </Items>
            </RadzenSelectBar>
        </RadzenStack>
    }
    
    @if (_chartData is not null && _chartData.Count >= 2)
    {
        <RadzenChart Style="height: 300px;" SeriesClick="@OnSeriesClick">
            <RadzenLineSeries Data="@_chartData" 
                              CategoryProperty="DateLabel" 
                              ValueProperty="Score" 
                              Title="Score"
                              Smooth="true">
                <TooltipTemplate Context="data">
                    <div class="rz-p-2">
                        <RadzenText TextStyle="TextStyle.Subtitle2" class="rz-mb-1">@data.CourseName</RadzenText>
                        <RadzenText TextStyle="TextStyle.Body2">Score: <strong>@data.Score</strong></RadzenText>
                        <RadzenText TextStyle="TextStyle.Caption" style="color: var(--rz-text-secondary-color);">
                            @data.DatePlayed.ToString("MMM d, yyyy")
                        </RadzenText>
                    </div>
                </TooltipTemplate>
            </RadzenLineSeries>

            @if (_trendLineData is not null && _trendLineData.Count >= 2)
            {
                <RadzenLineSeries Data="@_trendLineData"
                                  CategoryProperty="DateLabel"
                                  ValueProperty="Value"
                                  Title="Trend"
                                  LineType="LineType.Dashed"
                                  Smooth="false"
                                  StrokeWidth="2">
                    <ChildContent>
                        <RadzenMarkers Visible="false" />
                    </ChildContent>
                    <TooltipTemplate Context="data">
                        <div class="rz-p-2">
                            <RadzenText TextStyle="TextStyle.Body2">Trend: <strong>@data.Value</strong></RadzenText>
                        </div>
                    </TooltipTemplate>
                </RadzenLineSeries>
            }

            <RadzenValueAxis Min="@_minScore" Max="@_maxScore" Step="@_step">
                <RadzenGridLines Visible="true" />
                <RadzenAxisTitle Text="Score" />
            </RadzenValueAxis>
            <RadzenLegend Visible="true" />
        </RadzenChart>
    }
    else
    {
        <RadzenStack AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Center" Style="min-height: 300px;">
            <RadzenText TextStyle="TextStyle.Body2" style="color: var(--rz-text-secondary-color);">
                Not enough @(_selectedRoundType == "18" ? "18-hole" : "9-hole") rounds to show trend.
            </RadzenText>
        </RadzenStack>
    }
}

@code {
    [Parameter]
    public List<ScoreTrendPoint>? TrendData18Hole { get; set; }
    
    [Parameter]
    public List<ScoreTrendPoint>? TrendData9Hole { get; set; }

    private string _selectedRoundType = "18";
    private List<ScoreTrendChartItem>? _chartData;
    private List<TrendLinePoint>? _trendLineData;
    private int _minScore;
    private int _maxScore;
    private int _step = 5;

    protected override void OnParametersSet()
    {
        // If only one type has data, default to that type
        var hasData18 = TrendData18Hole is not null && TrendData18Hole.Count >= 2;
        var hasData9 = TrendData9Hole is not null && TrendData9Hole.Count >= 2;
        
        if (!hasData18 && hasData9)
        {
            _selectedRoundType = "9";
        }
        else if (hasData18 && !hasData9)
        {
            _selectedRoundType = "18";
        }
        
        UpdateChartData();
    }

    private void UpdateChartData()
    {
        var trendData = _selectedRoundType == "18" ? TrendData18Hole : TrendData9Hole;
        
        if (trendData is not null && trendData.Count >= 2)
        {
            // Transform to chart items with unique date labels (handle same-day rounds)
            _chartData = GenerateUniqueLabels(trendData);

            // Build trend line using the same unique labels so both series align
            var labels = _chartData.Select(d => d.DateLabel).ToList();
            _trendLineData = StatsCalculator.BuildScoreTrendLine(trendData, labels);

            // Calculate axis range with padding (include trend line values)
            var scores = _chartData.Select(d => (double)d.Score).ToList();
            if (_trendLineData.Count >= 2)
            {
                scores.AddRange(_trendLineData.Select(d => d.Value));
            }
            var minScore = scores.Min();
            var maxScore = scores.Max();

            // Round down/up to nearest 5 with padding
            _minScore = (int)(Math.Floor((minScore - 3) / 5.0) * 5);
            _maxScore = (int)(Math.Ceiling((maxScore + 3) / 5.0) * 5);

            // Ensure minimum range
            if (_maxScore - _minScore < 10)
            {
                _minScore -= 5;
                _maxScore += 5;
            }
        }
        else
        {
            _chartData = null;
            _trendLineData = null;
        }
    }

    private void OnRoundTypeChanged()
    {
        UpdateChartData();
    }

    private void OnSeriesClick(SeriesClickEventArgs args)
    {
        if (args.Data is ScoreTrendChartItem item)
        {
            NavigationManager.NavigateTo($"/round/{item.RoundId}");
        }
    }

    private const int MaxVisibleLabels = 6;

    /// <summary>
    /// Generates chart items with unique labels for each data point.
    /// To avoid x-axis clutter, only ~MaxVisibleLabels evenly-spaced points get a visible date label;
    /// the rest get a unique but invisible label (a single space + index) so data points still render
    /// at their own x position. Duplicate dates get a "(2)" suffix when visible.
    /// </summary>
    private static List<ScoreTrendChartItem> GenerateUniqueLabels(List<ScoreTrendPoint> trendData)
    {
        var n = trendData.Count;

        // Determine which indices get a visible label
        var visibleIndices = new HashSet<int>();
        if (n <= MaxVisibleLabels)
        {
            // Few enough points — show them all
            for (int i = 0; i < n; i++) visibleIndices.Add(i);
        }
        else
        {
            // Always show first and last, then evenly space the rest
            visibleIndices.Add(0);
            visibleIndices.Add(n - 1);
            var step = (double)(n - 1) / (MaxVisibleLabels - 1);
            for (int i = 1; i < MaxVisibleLabels - 1; i++)
            {
                visibleIndices.Add((int)Math.Round(step * i));
            }
        }

        var result = new List<ScoreTrendChartItem>();
        var labelCounts = new Dictionary<string, int>();

        for (int i = 0; i < n; i++)
        {
            var d = trendData[i];
            string label;

            if (visibleIndices.Contains(i))
            {
                var baseLabel = d.DatePlayed.ToString("M/d");
                if (labelCounts.TryGetValue(baseLabel, out var count))
                {
                    labelCounts[baseLabel] = count + 1;
                    label = $"{baseLabel} ({count + 1})";
                }
                else
                {
                    labelCounts[baseLabel] = 1;
                    label = baseLabel;
                }
            }
            else
            {
                // Visually blank but unique — repeat a non-breaking space i times so each label is distinct
                label = new string('\u00A0', i);
            }

            result.Add(new ScoreTrendChartItem
            {
                RoundId = d.RoundId,
                DatePlayed = d.DatePlayed,
                DateLabel = label,
                Score = d.Score,
                CourseName = d.CourseName
            });
        }

        return result;
    }

    // Internal class for chart binding with formatted date
    private class ScoreTrendChartItem
    {
        public long RoundId { get; set; }
        public DateOnly DatePlayed { get; set; }
        public string DateLabel { get; set; } = string.Empty;
        public int Score { get; set; }
        public string CourseName { get; set; } = string.Empty;
    }
}
