@using FairwayFinder.Features.Data
@using FairwayFinder.Web.Components.Pages.Home.Dialogs
@inject DialogService DialogService

@*
    Short-game stat cards (putts, up-and-down, 3-putts) with trend indicators.
    Shared by the user dashboard and the course stats pages.
    Set ShowTrendDialogs="false" to disable the trend dialogs (public viewers).
*@

@if (Stats.RoundsIncluded > 0)
{
    <RadzenStack Orientation="Orientation.Horizontal" Gap="1rem" Wrap="FlexWrap.Wrap">
        @if (Stats.Average18HolePutts.HasValue)
        {
            <FairwayFinderStatsCard
                Label="Avg Putts (18)"
                Value="@($"{Stats.Average18HolePutts:F1}")"
                SubText="per round"
                OnClick="ShowPuttsTrendDialog18Hole">
                @if (Stats.Average18HolePuttsTrend.HasValue)
                {
                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.25rem" JustifyContent="JustifyContent.Center">
                        @if (Stats.Average18HolePuttsTrend < 0)
                        {
                            <RadzenIcon Icon="trending_down" IconStyle="IconStyle.Success"/>
                            <RadzenText TextStyle="TextStyle.Caption">
                                @Stats.Average18HolePuttsTrend.Value.ToString("F1")
                            </RadzenText>
                        }
                        else
                        {
                            <RadzenIcon Icon="trending_up" IconStyle="IconStyle.Danger"/>
                            <RadzenText TextStyle="TextStyle.Caption">
                                + @Stats.Average18HolePuttsTrend.Value.ToString("F1")
                            </RadzenText>
                        }
                    </RadzenStack>
                }
            </FairwayFinderStatsCard>
        }

        @* Avg Putts (9) card — disabled for now
        @if (Stats.Average9HolePutts.HasValue)
        {
            <FairwayFinderStatsCard
                Label="Avg Putts (9)"
                Value="@($"{Stats.Average9HolePutts:F1}")"
                SubText="per round"
                OnClick="ShowPuttsTrendDialog9Hole">
            </FairwayFinderStatsCard>
        }
        *@

        @if (Stats.UpAndDownPercent.HasValue)
        {
            <FairwayFinderStatsCard
                Label="Up & Down"
                Value="@($"{Stats.UpAndDownPercent:F1}%")"
                SubText="@($"{Stats.RoundsIncluded} rounds")"
                OnClick="ShowUpAndDownTrendDialog">
                @if (Stats.UpAndDownPercentTrend.HasValue)
                {
                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.25rem" JustifyContent="JustifyContent.Center">
                        @if (Stats.UpAndDownPercentTrend > 0)
                        {
                            <RadzenIcon Icon="trending_up" IconStyle="IconStyle.Success"/>
                            <RadzenText TextStyle="TextStyle.Caption">
                                + @Stats.UpAndDownPercentTrend.Value.ToString("F1")%
                            </RadzenText>
                        }
                        else
                        {
                            <RadzenIcon Icon="trending_down" IconStyle="IconStyle.Danger"/>
                            <RadzenText TextStyle="TextStyle.Caption">
                                @Stats.UpAndDownPercentTrend.Value.ToString("F1")%
                            </RadzenText>
                        }
                    </RadzenStack>
                }
            </FairwayFinderStatsCard>
        }

        @if (Stats.Average18HoleThreePutts.HasValue)
        {
            <FairwayFinderStatsCard
                Label="3-Putts (18)"
                Value="@($"{Stats.Average18HoleThreePutts:F1}")"
                SubText="per round"
                OnClick="ShowThreePuttsTrendDialog18Hole">
                @if (Stats.Average18HoleThreePuttsTrend.HasValue)
                {
                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.25rem" JustifyContent="JustifyContent.Center">
                        @if (Stats.Average18HoleThreePuttsTrend < 0)
                        {
                            <RadzenIcon Icon="trending_down" IconStyle="IconStyle.Success"/>
                            <RadzenText TextStyle="TextStyle.Caption">
                                @Stats.Average18HoleThreePuttsTrend.Value.ToString("F1")
                            </RadzenText>
                        }
                        else
                        {
                            <RadzenIcon Icon="trending_up" IconStyle="IconStyle.Danger"/>
                            <RadzenText TextStyle="TextStyle.Caption">
                                + @Stats.Average18HoleThreePuttsTrend.Value.ToString("F1")
                            </RadzenText>
                        }
                    </RadzenStack>
                }
            </FairwayFinderStatsCard>
        }

        @* 3-Putts (9) card — disabled for now
        @if (Stats.Average9HoleThreePutts.HasValue)
        {
            <FairwayFinderStatsCard
                Label="3-Putts (9)"
                Value="@($"{Stats.Average9HoleThreePutts:F1}")"
                SubText="per round"
                OnClick="ShowThreePuttsTrendDialog9Hole">
            </FairwayFinderStatsCard>
        }
        *@
    </RadzenStack>
}

@code {
    /// <summary>Short-game stats to display.</summary>
    [Parameter, EditorRequired]
    public ShortGameStats Stats { get; set; } = new();

    /// <summary>When false, clicking a card does not open a trend dialog (public viewers).</summary>
    [Parameter]
    public bool ShowTrendDialogs { get; set; } = true;

    private async Task ShowPuttsTrendDialog18Hole()
    {
        if (!ShowTrendDialogs) return;
        if (Stats.PuttsTrend18Hole.Count < 2) return;

        await DialogService.OpenAsync<PuttsTrendDialog>("Putting Trend (18-Hole Rounds)",
            new Dictionary<string, object>
            {
                { "TrendData", Stats.PuttsTrend18Hole }
            },
            new DialogOptions
            {
                Width = "700px",
                CloseDialogOnOverlayClick = true,
                CloseDialogOnEsc = true
            });
    }

    private async Task ShowPuttsTrendDialog9Hole()
    {
        if (!ShowTrendDialogs) return;
        if (Stats.PuttsTrend9Hole.Count < 2) return;

        await DialogService.OpenAsync<PuttsTrendDialog>("Putting Trend (9-Hole Rounds)",
            new Dictionary<string, object>
            {
                { "TrendData", Stats.PuttsTrend9Hole }
            },
            new DialogOptions
            {
                Width = "700px",
                CloseDialogOnOverlayClick = true,
                CloseDialogOnEsc = true
            });
    }

    private async Task ShowUpAndDownTrendDialog()
    {
        if (!ShowTrendDialogs) return;
        if (Stats.UpAndDownTrend.Count < 2) return;

        await DialogService.OpenAsync<UpAndDownTrendDialog>("Up & Down Trend",
            new Dictionary<string, object>
            {
                { "TrendData", Stats.UpAndDownTrend }
            },
            new DialogOptions
            {
                Width = "700px",
                CloseDialogOnOverlayClick = true,
                CloseDialogOnEsc = true
            });
    }

    private async Task ShowThreePuttsTrendDialog18Hole()
    {
        if (!ShowTrendDialogs) return;
        if (Stats.ThreePuttsTrend18Hole.Count < 2) return;

        await DialogService.OpenAsync<ThreePuttsTrendDialog>("3-Putts Trend (18-Hole Rounds)",
            new Dictionary<string, object>
            {
                { "TrendData", Stats.ThreePuttsTrend18Hole }
            },
            new DialogOptions
            {
                Width = "700px",
                CloseDialogOnOverlayClick = true,
                CloseDialogOnEsc = true
            });
    }

    private async Task ShowThreePuttsTrendDialog9Hole()
    {
        if (!ShowTrendDialogs) return;
        if (Stats.ThreePuttsTrend9Hole.Count < 2) return;

        await DialogService.OpenAsync<ThreePuttsTrendDialog>("3-Putts Trend (9-Hole Rounds)",
            new Dictionary<string, object>
            {
                { "TrendData", Stats.ThreePuttsTrend9Hole }
            },
            new DialogOptions
            {
                Width = "700px",
                CloseDialogOnOverlayClick = true,
                CloseDialogOnEsc = true
            });
    }
}
