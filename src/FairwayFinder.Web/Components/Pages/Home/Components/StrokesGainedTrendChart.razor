@using FairwayFinder.Features.Data
@inject NavigationManager NavigationManager

@{
    var hasTotal = TotalTrend is not null && TotalTrend.Count >= 2;
    var hasPutting = PuttingTrend is not null && PuttingTrend.Count >= 2;
    var hasT2G = TeeToGreenTrend is not null && TeeToGreenTrend.Count >= 2;
    var hasAnyData = hasTotal || hasPutting || hasT2G;
}

@if (!hasAnyData)
{
    <RadzenStack AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Center" Style="min-height: 300px;">
        <RadzenText TextStyle="TextStyle.Body2" style="color: var(--rz-text-secondary-color);">
            Not enough rounds with shot data to show strokes gained trend.
        </RadzenText>
    </RadzenStack>
}
else
{
    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" class="rz-mb-2">
        <RadzenSelectBar @bind-Value="_selectedCategory" TValue="string" Size="ButtonSize.Medium" Change="@OnCategoryChanged">
            <Items>
                @if (hasTotal)
                {
                    <RadzenSelectBarItem Text="Total" Value="@("Total")" />
                }
                @if (hasPutting)
                {
                    <RadzenSelectBarItem Text="Putting" Value="@("Putting")" />
                }
                @if (hasT2G)
                {
                    <RadzenSelectBarItem Text="T2G" Value="@("T2G")" />
                }
            </Items>
        </RadzenSelectBar>
    </RadzenStack>

    @if (_chartData is not null && _chartData.Count >= 2)
    {
        <RadzenChart Style="height: 300px;" SeriesClick="@OnSeriesClick">
            <RadzenLineSeries Data="@_chartData"
                              CategoryProperty="DateLabel"
                              ValueProperty="Value"
                              Title="@GetSeriesTitle()"
                              Smooth="true">
                <TooltipTemplate Context="data">
                    <div class="rz-p-2">
                        <RadzenText TextStyle="TextStyle.Subtitle2" class="rz-mb-1">@data.CourseName</RadzenText>
                        <RadzenText TextStyle="TextStyle.Body2">SG: <strong>@FormatSgValue(data.Value)</strong></RadzenText>
                        <RadzenText TextStyle="TextStyle.Caption" style="color: var(--rz-text-secondary-color);">
                            @data.DatePlayed.ToString("MMM d, yyyy")
                        </RadzenText>
                    </div>
                </TooltipTemplate>
            </RadzenLineSeries>

            @if (_movingAverageData is not null && _movingAverageData.Count >= 2)
            {
                <RadzenLineSeries Data="@_movingAverageData"
                                  CategoryProperty="DateLabel"
                                  ValueProperty="Value"
                                  Title="Moving Avg"
                                  LineType="LineType.Dashed"
                                  Smooth="false"
                                  StrokeWidth="2">
                    <ChildContent>
                        <RadzenMarkers Visible="false" />
                    </ChildContent>
                    <TooltipTemplate Context="data">
                        <div class="rz-p-2">
                            <RadzenText TextStyle="TextStyle.Body2">Avg: <strong>@FormatSgValue(data.Value)</strong></RadzenText>
                        </div>
                    </TooltipTemplate>
                </RadzenLineSeries>
            }

            @if (_zeroLineData is not null && _zeroLineData.Count >= 2)
            {
                <RadzenLineSeries Data="@_zeroLineData"
                                  CategoryProperty="DateLabel"
                                  ValueProperty="Value"
                                  Title="Baseline"
                                  LineType="LineType.Dashed"
                                  Smooth="false"
                                  StrokeWidth="1">
                    <ChildContent>
                        <RadzenMarkers Visible="false" />
                    </ChildContent>
                </RadzenLineSeries>
            }

            <RadzenValueAxis Min="@_minValue" Max="@_maxValue" Step="@_step">
                <RadzenGridLines Visible="true" />
                <RadzenAxisTitle Text="Strokes Gained" />
            </RadzenValueAxis>
            <RadzenLegend Visible="true" />
        </RadzenChart>
    }
    else
    {
        <RadzenStack AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Center" Style="min-height: 300px;">
            <RadzenText TextStyle="TextStyle.Body2" style="color: var(--rz-text-secondary-color);">
                Not enough data for this category.
            </RadzenText>
        </RadzenStack>
    }
}

@code {
    [Parameter]
    public List<StrokesGainedTrendPoint>? TotalTrend { get; set; }

    [Parameter]
    public List<StrokesGainedTrendPoint>? PuttingTrend { get; set; }

    [Parameter]
    public List<StrokesGainedTrendPoint>? TeeToGreenTrend { get; set; }

    private string _selectedCategory = "Total";
    private List<SgTrendChartItem>? _chartData;
    private List<TrendLinePoint>? _movingAverageData;
    private List<TrendLinePoint>? _zeroLineData;
    private double _minValue;
    private double _maxValue;
    private double _step = 1;

    protected override void OnParametersSet()
    {
        // Default to first available category
        var hasTotal = TotalTrend is not null && TotalTrend.Count >= 2;
        var hasPutting = PuttingTrend is not null && PuttingTrend.Count >= 2;
        var hasT2G = TeeToGreenTrend is not null && TeeToGreenTrend.Count >= 2;

        if (_selectedCategory == "Total" && !hasTotal)
        {
            _selectedCategory = hasPutting ? "Putting" : hasT2G ? "T2G" : "Total";
        }

        UpdateChartData();
    }

    private void UpdateChartData()
    {
        var trendData = _selectedCategory switch
        {
            "Putting" => PuttingTrend,
            "T2G" => TeeToGreenTrend,
            _ => TotalTrend
        };

        if (trendData is not null && trendData.Count >= 2)
        {
            _chartData = GenerateUniqueLabels(trendData);

            // Build moving average line from precomputed values
            _movingAverageData = _chartData
                .Where(d => d.MovingAverage.HasValue)
                .Select(d => new TrendLinePoint
                {
                    DateLabel = d.DateLabel,
                    Value = Math.Round(d.MovingAverage!.Value, 2)
                })
                .ToList();

            // Build zero line
            _zeroLineData = _chartData
                .Select(d => new TrendLinePoint
                {
                    DateLabel = d.DateLabel,
                    Value = 0
                })
                .ToList();

            // Calculate axis range
            var values = _chartData.Select(d => d.Value).ToList();
            if (_movingAverageData.Count >= 2)
            {
                values.AddRange(_movingAverageData.Select(d => d.Value));
            }
            var minVal = values.Min();
            var maxVal = values.Max();

            _minValue = Math.Floor(minVal - 0.5);
            _maxValue = Math.Ceiling(maxVal + 0.5);

            // Ensure minimum range and zero is visible
            if (_minValue > 0) _minValue = 0;
            if (_maxValue < 0) _maxValue = 0;
            if (_maxValue - _minValue < 2)
            {
                _minValue -= 1;
                _maxValue += 1;
            }

            _step = (_maxValue - _minValue) > 6 ? 2 : 1;
        }
        else
        {
            _chartData = null;
            _movingAverageData = null;
            _zeroLineData = null;
        }
    }

    private void OnCategoryChanged()
    {
        UpdateChartData();
    }

    private string GetSeriesTitle()
    {
        return _selectedCategory switch
        {
            "Putting" => "SG:Putting",
            "T2G" => "SG:T2G",
            _ => "SG:Total"
        };
    }

    private void OnSeriesClick(SeriesClickEventArgs args)
    {
        if (args.Data is SgTrendChartItem item)
        {
            NavigationManager.NavigateTo($"/round/{item.RoundId}");
        }
    }

    private static string FormatSgValue(double value)
    {
        return value >= 0 ? $"+{value:F2}" : $"{value:F2}";
    }

    private const int MaxVisibleLabels = 6;

    private static List<SgTrendChartItem> GenerateUniqueLabels(List<StrokesGainedTrendPoint> trendData)
    {
        var n = trendData.Count;
        var visibleIndices = new HashSet<int>();
        if (n <= MaxVisibleLabels)
        {
            for (int i = 0; i < n; i++) visibleIndices.Add(i);
        }
        else
        {
            visibleIndices.Add(0);
            visibleIndices.Add(n - 1);
            var step = (double)(n - 1) / (MaxVisibleLabels - 1);
            for (int i = 1; i < MaxVisibleLabels - 1; i++)
                visibleIndices.Add((int)Math.Round(step * i));
        }

        var result = new List<SgTrendChartItem>();
        var labelCounts = new Dictionary<string, int>();

        for (int i = 0; i < n; i++)
        {
            var d = trendData[i];
            string label;

            if (visibleIndices.Contains(i))
            {
                var baseLabel = d.DatePlayed.ToString("M/d");
                if (labelCounts.TryGetValue(baseLabel, out var count))
                {
                    labelCounts[baseLabel] = count + 1;
                    label = $"{baseLabel} ({count + 1})";
                }
                else
                {
                    labelCounts[baseLabel] = 1;
                    label = baseLabel;
                }
            }
            else
            {
                label = new string('\u00A0', i);
            }

            result.Add(new SgTrendChartItem
            {
                RoundId = d.RoundId,
                DatePlayed = d.DatePlayed,
                DateLabel = label,
                Value = d.Value,
                MovingAverage = d.MovingAverage,
                CourseName = d.CourseName
            });
        }

        return result;
    }

    private class SgTrendChartItem
    {
        public long RoundId { get; set; }
        public DateOnly DatePlayed { get; set; }
        public string DateLabel { get; set; } = string.Empty;
        public double Value { get; set; }
        public double? MovingAverage { get; set; }
        public string CourseName { get; set; } = string.Empty;
    }
}
