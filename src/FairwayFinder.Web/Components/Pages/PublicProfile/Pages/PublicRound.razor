@page "/profile/{PublicId:guid}/round/{RoundId:long}"
@page "/friends/{PublicId:guid}/round/{RoundId:long}"
@rendermode InteractiveServer
@layout MainLayout
@attribute [AllowAnonymous]
@using System.Security.Claims
@using FairwayFinder.Features.Data
@using FairwayFinder.Features.Services.Interfaces
@using FairwayFinder.Web.Components.Pages.Rounds.Components
@using FairwayFinder.Web.Components.Shared.Layout.Breadcrumb
@inject IProfileService ProfileService
@inject IRoundService RoundService
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject BreadcrumbState BreadcrumbState

<PageTitle>View Round</PageTitle>

@if (_loading)
{
    <RadzenStack AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Center" class="rz-p-8">
        <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
    </RadzenStack>
}
else if (_round is null)
{
    <RadzenCard class="rz-p-5">
        <RadzenAlert AlertStyle="AlertStyle.Warning" Shade="Shade.Lighter" AllowClose="false">
            @_errorMessage
        </RadzenAlert>
        @if (_profile is not null)
        {
            <RadzenButton Text="Back to Profile" Icon="arrow_back" ButtonStyle="ButtonStyle.Secondary"
                          Click="@(() => NavigationManager.NavigateTo(_basePath))" class="rz-mt-4" />
        }
    </RadzenCard>
}
else
{
    <RadzenStack Gap="1.5rem">
        <!-- Header -->
        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Start">
            <RadzenStack Gap="0.25rem">
                <RadzenText TextStyle="TextStyle.H3" class="rz-m-0">@_round.CourseName</RadzenText>
                <RadzenStack Orientation="Orientation.Horizontal" Gap="2rem">
                    <RadzenText TextStyle="TextStyle.Body2" style="color: var(--rz-text-secondary-color);">
                        Tee Box: @_round.Teebox.TeeboxName
                    </RadzenText>
                    <RadzenText TextStyle="TextStyle.Body2" style="color: var(--rz-text-secondary-color);">
                        Date: @_round.DatePlayed.ToString("M/d/yy")
                    </RadzenText>
                </RadzenStack>
            </RadzenStack>

            <RadzenButton Text="@_backLabel" Icon="arrow_back" ButtonStyle="ButtonStyle.Light"
                          Variant="Variant.Outlined"
                          Click="@(() => NavigationManager.NavigateTo(_basePath))" />
        </RadzenStack>

        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.Start">
            <!-- Scoring Breakdown Pills -->
            <RoundScoringPills Round="@_round" />
        </RadzenStack>

        <!-- Scorecard -->
        <FairwayFinderScorecard Round="@_round" />

        <!-- Round Stats -->
        <RoundStatsPanel Round="@_round" />
    </RadzenStack>
}

@code {
    [Parameter]
    public Guid PublicId { get; set; }

    [Parameter]
    public long RoundId { get; set; }

    private UserProfileResponse? _profile;
    private RoundResponse? _round;
    private bool _loading = true;
    private string _errorMessage = "Round not found.";
    private bool _isFriendRoute;
    private string _basePath = string.Empty;
    private string _backLabel = "Back to Profile";

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;

        _isFriendRoute = NavigationManager.ToBaseRelativePath(NavigationManager.Uri)
            .StartsWith("friends/", StringComparison.OrdinalIgnoreCase);
        _basePath = _isFriendRoute ? $"/friends/{PublicId}" : $"/profile/{PublicId}";
        _backLabel = _isFriendRoute ? "Back to Friend" : "Back to Profile";

        // 1. Validate the profile (friend-aware when on the /friends route)
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var viewerUserId = authState.User.FindFirstValue(ClaimTypes.NameIdentifier);
        _profile = await ProfileService.GetProfileForViewerAsync(PublicId, viewerUserId);

        if (_profile is null)
        {
            _errorMessage = "This profile is not available. It may be private or may not exist.";
            _loading = false;
            return;
        }

        // 2. Load the round
        _round = await RoundService.GetRoundByIdAsync(RoundId);

        // 3. Verify the round belongs to this profile's user
        if (_round is not null)
        {
            var isOwned = await RoundService.IsRoundOwnedByUserAsync(RoundId, _profile.UserId);
            if (!isOwned)
            {
                _round = null;
                _errorMessage = "Round not found or does not belong to this profile.";
            }
        }

        if (_isFriendRoute)
        {
            BreadcrumbState.Set(
                new BreadcrumbItem("Friends", "/friends"),
                new BreadcrumbItem(_profile.DisplayName ?? "Friend", _basePath),
                new BreadcrumbItem($"{_round?.CourseName} - {_round?.DatePlayed:M/d/yy}")
            );
        }
        else
        {
            BreadcrumbState.Set(
                new BreadcrumbItem("Dashboard", _basePath),
                new BreadcrumbItem($"{_round?.CourseName} - {_round?.DatePlayed:M/d/yy}")
            );
        }

        _loading = false;
    }
}
