@using FairwayFinder.Features.Data
@using FairwayFinder.Features.Enums
@using FairwayFinder.Features.Helpers
@using FairwayFinder.Web.Components.Pages.Rounds.Dialogs

<RadzenStack Gap="0.25rem" class="rz-mb-2">
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
        <RadzenStack Gap="0">
            <RadzenText TextStyle="TextStyle.H5" class="rz-m-0">Scorecard</RadzenText>
            <RadzenText TextStyle="TextStyle.Caption" style="color: var(--rz-text-secondary-color);">Step 2 of 3 &middot; @State.SelectedCourseName</RadzenText>
        </RadzenStack>
        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" AlignItems="AlignItems.Center">
            <RadzenButton Text="Scan Scorecard" Icon="photo_camera"
                          ButtonStyle="ButtonStyle.Secondary" Variant="Variant.Outlined"
                          Click="@OnScanScorecardClicked" />
            <RadzenButton Text="Back to Setup" Icon="arrow_back"
                          ButtonStyle="ButtonStyle.Light" Variant="Variant.Outlined"
                          Click="@OnBackClicked" />
        </RadzenStack>
    </RadzenStack>
</RadzenStack>

<div class="scorecard-wrapper">
    <table class="scorecard-table">
        <thead>
            <tr>
                <th colspan="2">Hole</th>
                @foreach (var hole in FrontNineHoles)
                {
                    <th class="hole-cell">@hole.HoleNumber</th>
                }
                <th class="total-cell" colspan="2">Out</th>
                @foreach (var hole in BackNineHoles)
                {
                    <th class="hole-cell">@hole.HoleNumber</th>
                }
                <th class="total-cell" colspan="2">In</th>
                <th class="total-cell" colspan="2">Total</th>
            </tr>
        </thead>
        <tbody>
            @* Yardage Row *@
            <tr>
                <th colspan="2">@State.SelectedTeeboxName</th>
                @foreach (var hole in FrontNineHoles)
                {
                    <td class="hole-cell">@hole.Yardage</td>
                }
                <td class="total-cell" colspan="2">@FrontNineHoles.Sum(h => h.Yardage)</td>
                @foreach (var hole in BackNineHoles)
                {
                    <td class="hole-cell">@hole.Yardage</td>
                }
                <td class="total-cell" colspan="2">@BackNineHoles.Sum(h => h.Yardage)</td>
                <td class="total-cell" colspan="2">@State.Holes.Sum(h => h.Yardage)</td>
            </tr>

            @* Handicap Row *@
            <tr>
                <th colspan="2">Handicap</th>
                @foreach (var hole in FrontNineHoles)
                {
                    <td class="hole-cell">@hole.Handicap</td>
                }
                <td class="total-cell" colspan="2">&nbsp;</td>
                @foreach (var hole in BackNineHoles)
                {
                    <td class="hole-cell">@hole.Handicap</td>
                }
                <td class="total-cell" colspan="2">&nbsp;</td>
                <td class="total-cell" colspan="2">&nbsp;</td>
            </tr>

            @* Par Row *@
            <tr>
                <th colspan="2">Par</th>
                @foreach (var hole in FrontNineHoles)
                {
                    <td class="hole-cell">@hole.Par</td>
                }
                <td class="total-cell" colspan="2">@FrontNineHoles.Sum(h => h.Par)</td>
                @foreach (var hole in BackNineHoles)
                {
                    <td class="hole-cell">@hole.Par</td>
                }
                <td class="total-cell" colspan="2">@BackNineHoles.Sum(h => h.Par)</td>
                <td class="total-cell" colspan="2">@State.Holes.Sum(h => h.Par)</td>
            </tr>

            @* Score Row (editable) *@
            <tr class="score-row">
                <th colspan="2">Score</th>
                @foreach (var entry in FrontNineEntries)
                {
                    <td class="hole-cell input-cell">
                        <input type="text" inputmode="numeric" class="scorecard-input"
                               style="@GetScoreInputStyle(entry)"
                               value="@entry.Score"
                               @onchange="(e) => OnScoreChanged(entry, e)" />
                    </td>
                }
                <td class="total-cell" colspan="2">@RunningScoreOut</td>
                @foreach (var entry in BackNineEntries)
                {
                    <td class="hole-cell input-cell">
                        <input type="text" inputmode="numeric" class="scorecard-input"
                               style="@GetScoreInputStyle(entry)"
                               value="@entry.Score"
                               @onchange="(e) => OnScoreChanged(entry, e)" />
                    </td>
                }
                <td class="total-cell" colspan="2">@RunningScoreIn</td>
                <td class="total-cell" colspan="2">@RunningScoreTotal</td>
            </tr>

            @if (State.TrackShotByShotStats)
            {
                @* Shots Row (clickable cells that open shot entry dialog) *@
                <tr>
                    <th colspan="2">Shots</th>
                    @foreach (var entry in FrontNineEntries)
                    {
                        var hole = State.Holes.First(h => h.HoleNumber == entry.HoleNumber);
                        <td class="hole-cell toggle-cell" @onclick="() => OpenShotDialog(entry, hole)">
                            @if (entry.Shots is { Count: > 0 } && IsHoleComplete(entry))
                            {
                                <span style="@GetShotsCellStyle(entry)">@entry.Shots.Count</span>
                            }
                            else if (entry.Shots is { Count: > 0 })
                            {
                                <span style="color: var(--rz-warning); cursor: pointer;">@entry.Shots.Count...</span>
                            }
                            else
                            {
                                <span class="toggle-placeholder">-</span>
                            }
                        </td>
                    }
                    <td class="total-cell" colspan="2">@FrontNineShotCount</td>
                    @foreach (var entry in BackNineEntries)
                    {
                        var hole = State.Holes.First(h => h.HoleNumber == entry.HoleNumber);
                        <td class="hole-cell toggle-cell" @onclick="() => OpenShotDialog(entry, hole)">
                            @if (entry.Shots is { Count: > 0 } && IsHoleComplete(entry))
                            {
                                <span style="@GetShotsCellStyle(entry)">@entry.Shots.Count</span>
                            }
                            else if (entry.Shots is { Count: > 0 })
                            {
                                <span style="color: var(--rz-warning); cursor: pointer;">@entry.Shots.Count...</span>
                            }
                            else
                            {
                                <span class="toggle-placeholder">-</span>
                            }
                        </td>
                    }
                    <td class="total-cell" colspan="2">@BackNineShotCount</td>
                    <td class="total-cell" colspan="2">@TotalShotCount</td>
                </tr>

                @* SG Row (computed from shots, read-only) *@
                <tr>
                    <th colspan="2">SG</th>
                    @foreach (var entry in FrontNineEntries)
                    {
                        <td class="hole-cell">
                            @if (entry.Shots is { Count: > 0 } && IsHoleComplete(entry))
                            {
                                var sg = GetHoleSg(entry);
                                <span style="@($"color: {(sg >= 0 ? "var(--rz-success)" : "var(--rz-danger)")}"); font-size: 0.75rem;">
                                    @sg.ToString("+0.00;-0.00")
                                </span>
                            }
                            else
                            {
                                <span style="color: var(--rz-text-disabled-color);">-</span>
                            }
                        </td>
                    }
                    <td class="total-cell" colspan="2" style="font-size: 0.75rem;">@FormatSgTotal(FrontNineEntries)</td>
                    @foreach (var entry in BackNineEntries)
                    {
                        <td class="hole-cell">
                            @if (entry.Shots is { Count: > 0 } && IsHoleComplete(entry))
                            {
                                var sg = GetHoleSg(entry);
                                <span style="@($"color: {(sg >= 0 ? "var(--rz-success)" : "var(--rz-danger)")}"); font-size: 0.75rem;">
                                    @sg.ToString("+0.00;-0.00")
                                </span>
                            }
                            else
                            {
                                <span style="color: var(--rz-text-disabled-color);">-</span>
                            }
                        </td>
                    }
                    <td class="total-cell" colspan="2" style="font-size: 0.75rem;">@FormatSgTotal(BackNineEntries)</td>
                    <td class="total-cell" colspan="2" style="font-size: 0.75rem;">@FormatSgTotal(State.HoleEntries)</td>
                </tr>
            }

            @if (State.TrackAdvancedStats && !State.TrackShotByShotStats)
            {
                @* Putts Row (editable) *@
                <tr>
                    <th colspan="2">Putts</th>
                    @foreach (var entry in FrontNineEntries)
                    {
                        <td class="hole-cell input-cell">
                            <input type="text" inputmode="numeric" class="scorecard-input"
                                   value="@entry.NumberOfPutts"
                                   @onchange="(e) => OnPuttsChanged(entry, e)" />
                        </td>
                    }
                    <td class="total-cell" colspan="2">@FrontNineEntries.Where(e => e.NumberOfPutts.HasValue).Sum(e => (int)e.NumberOfPutts!.Value)</td>
                    @foreach (var entry in BackNineEntries)
                    {
                        <td class="hole-cell input-cell">
                            <input type="text" inputmode="numeric" class="scorecard-input"
                                   value="@entry.NumberOfPutts"
                                   @onchange="(e) => OnPuttsChanged(entry, e)" />
                        </td>
                    }
                    <td class="total-cell" colspan="2">@BackNineEntries.Where(e => e.NumberOfPutts.HasValue).Sum(e => (int)e.NumberOfPutts!.Value)</td>
                    <td class="total-cell" colspan="2">@State.HoleEntries.Where(e => e.NumberOfPutts.HasValue).Sum(e => (int)e.NumberOfPutts!.Value)</td>
                </tr>

                @* Fairway Row (clickable toggles with miss direction) *@
                <tr>
                    <th colspan="2">Fairway</th>
                    @foreach (var entry in FrontNineEntries)
                    {
                        <td class="hole-cell toggle-cell" @onclick="() => ToggleFairway(entry)">
                            @if (entry.Par <= 3)
                            {
                                <span>&nbsp;</span>
                            }
                            else if (entry.HitFairway == true)
                            {
                                <RadzenIcon Icon="check_circle" Style="color: var(--rz-success); cursor: pointer;" />
                            }
                            else if (entry.HitFairway == false)
                            {
                                <RadzenIcon Icon="@GetMissIcon(entry.MissFairwayType)" Style="color: var(--rz-danger); cursor: pointer;" />
                            }
                            else
                            {
                                <span class="toggle-placeholder">-</span>
                            }
                        </td>
                    }
                    <td class="total-cell" colspan="2">@FrontNineFairwaysHit / @FrontNineFairwaysTotal</td>
                    @foreach (var entry in BackNineEntries)
                    {
                        <td class="hole-cell toggle-cell" @onclick="() => ToggleFairway(entry)">
                            @if (entry.Par <= 3)
                            {
                                <span>&nbsp;</span>
                            }
                            else if (entry.HitFairway == true)
                            {
                                <RadzenIcon Icon="check_circle" Style="color: var(--rz-success); cursor: pointer;" />
                            }
                            else if (entry.HitFairway == false)
                            {
                                <RadzenIcon Icon="@GetMissIcon(entry.MissFairwayType)" Style="color: var(--rz-danger); cursor: pointer;" />
                            }
                            else
                            {
                                <span class="toggle-placeholder">-</span>
                            }
                        </td>
                    }
                    <td class="total-cell" colspan="2">@BackNineFairwaysHit / @BackNineFairwaysTotal</td>
                    <td class="total-cell" colspan="2">@TotalFairwaysHit / @TotalFairwaysTotal</td>
                </tr>

                @* GIR Row (clickable toggles with miss direction) *@
                <tr>
                    <th colspan="2">GIR</th>
                    @foreach (var entry in FrontNineEntries)
                    {
                        <td class="hole-cell toggle-cell" @onclick="() => ToggleGir(entry)">
                            @if (entry.HitGreen == true)
                            {
                                <RadzenIcon Icon="check_circle" Style="color: var(--rz-success); cursor: pointer;" />
                            }
                            else if (entry.HitGreen == false)
                            {
                                <RadzenIcon Icon="@GetMissIcon(entry.MissGreenType)" Style="color: var(--rz-danger); cursor: pointer;" />
                            }
                            else
                            {
                                <span class="toggle-placeholder">-</span>
                            }
                        </td>
                    }
                    <td class="total-cell" colspan="2">@FrontNineGreensHit</td>
                    @foreach (var entry in BackNineEntries)
                    {
                        <td class="hole-cell toggle-cell" @onclick="() => ToggleGir(entry)">
                            @if (entry.HitGreen == true)
                            {
                                <RadzenIcon Icon="check_circle" Style="color: var(--rz-success); cursor: pointer;" />
                            }
                            else if (entry.HitGreen == false)
                            {
                                <RadzenIcon Icon="@GetMissIcon(entry.MissGreenType)" Style="color: var(--rz-danger); cursor: pointer;" />
                            }
                            else
                            {
                                <span class="toggle-placeholder">-</span>
                            }
                        </td>
                    }
                    <td class="total-cell" colspan="2">@BackNineGreensHit</td>
                    <td class="total-cell" colspan="2">@TotalGreensHit / @State.HoleEntries.Count</td>
                </tr>

                @* Approach Yardage Row (editable) *@
                <tr>
                    <th colspan="2">Approach</th>
                    @foreach (var entry in FrontNineEntries)
                    {
                        <td class="hole-cell input-cell">
                            <input type="text" inputmode="numeric" class="scorecard-input"
                                   value="@entry.ApproachYardage"
                                   @onchange="(e) => OnApproachYardageChanged(entry, e)" />
                        </td>
                    }
                    <td class="total-cell" colspan="2">&nbsp;</td>
                    @foreach (var entry in BackNineEntries)
                    {
                        <td class="hole-cell input-cell">
                            <input type="text" inputmode="numeric" class="scorecard-input"
                                   value="@entry.ApproachYardage"
                                   @onchange="(e) => OnApproachYardageChanged(entry, e)" />
                        </td>
                    }
                    <td class="total-cell" colspan="2">&nbsp;</td>
                    <td class="total-cell" colspan="2">&nbsp;</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" class="rz-pt-2">
    <RadzenButton Text="Review" Icon="arrow_forward" ButtonStyle="ButtonStyle.Primary" Click="@OnReviewClicked" />
</RadzenStack>

<style>
    .scorecard-wrapper {
        width: 100%;
        overflow-x: auto;
    }

    .scorecard-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.875rem;
        min-width: 900px;
        border-top: 1px solid var(--rz-text-disabled-color);
        border-bottom: 1px solid var(--rz-text-disabled-color);
        border-left: 1px solid var(--rz-text-disabled-color);
        border-right: 1px solid var(--rz-text-disabled-color);
    }

    .scorecard-table th,
    .scorecard-table td {
        padding: 0.5rem 0.25rem;
        text-align: center;
        border-top: 1px solid var(--rz-text-disabled-color);
        border-bottom: 1px solid var(--rz-text-disabled-color);
        border-left: none;
        border-right: none;
    }

    .scorecard-table th:first-child,
    .scorecard-table td:first-child {
        border-left: 1px solid var(--rz-text-disabled-color);
    }

    .scorecard-table th:last-child,
    .scorecard-table td:last-child {
        border-right: 1px solid var(--rz-text-disabled-color);
    }

    .scorecard-table thead th {
        background-color: var(--rz-base-background-color);
        font-weight: 600;
    }

    .scorecard-table tbody th {
        text-align: left;
        padding-left: 0.5rem;
        background-color: var(--rz-base-background-color);
        font-weight: 600;
        min-width: 80px;
    }

    .scorecard-table .hole-cell {
        min-width: 36px;
        width: 36px;
    }

    .scorecard-table .total-cell {
        font-weight: 600;
        background-color: var(--rz-base-background-color);
        min-width: 45px;
    }

    .scorecard-table .score-row {
        font-weight: 600;
        font-size: 1rem;
    }

    .scorecard-table .input-cell {
        padding: 0.125rem;
    }

    .scorecard-table .toggle-cell {
        cursor: pointer;
        user-select: none;
    }

    .scorecard-table .toggle-cell:hover {
        background-color: var(--rz-base-background-color);
    }

    .toggle-placeholder {
        color: var(--rz-text-disabled-color);
        cursor: pointer;
    }

    .scorecard-input {
        width: 100%;
        min-width: 36px;
        text-align: center;
        padding: 0.25rem 0;
        font-size: 0.875rem;
        border: 1px dashed var(--rz-text-disabled-color);
        border-radius: var(--rz-border-radius);
        background: transparent;
        color: inherit;
        outline: none;
        box-sizing: border-box;
    }

    .scorecard-input:focus {
        border-color: var(--rz-primary);
    }
</style>

@code {
    [Parameter, EditorRequired]
    public CreateRoundState State { get; set; } = default!;

    [Parameter]
    public EventCallback OnBack { get; set; }

    [Parameter]
    public EventCallback OnReview { get; set; }

    [Parameter]
    public EventCallback OnScanScorecard { get; set; }

    [Inject]
    public DialogService DialogService { get; set; } = default!;

    // Computed: hole/entry splits for front/back nine
    private List<HoleInfo> FrontNineHoles => State.Holes.Where(h => h.HoleNumber <= 9).ToList();
    private List<HoleInfo> BackNineHoles => State.Holes.Where(h => h.HoleNumber > 9).ToList();
    private List<HoleScoreEntry> FrontNineEntries => State.HoleEntries.Where(e => e.HoleNumber <= 9).ToList();
    private List<HoleScoreEntry> BackNineEntries => State.HoleEntries.Where(e => e.HoleNumber > 9).ToList();

    // Running score totals
    private int RunningScoreOut => State.HoleEntries.Where(h => h.HoleNumber <= 9).Sum(h => (int)h.Score);
    private int RunningScoreIn => State.HoleEntries.Where(h => h.HoleNumber > 9).Sum(h => (int)h.Score);
    private int RunningScoreTotal => RunningScoreOut + RunningScoreIn;

    // Fairway totals
    private int FrontNineFairwaysHit => FrontNineEntries.Count(e => e.HitFairway == true);
    private int FrontNineFairwaysTotal => FrontNineEntries.Count(e => e.Par > 3);
    private int BackNineFairwaysHit => BackNineEntries.Count(e => e.HitFairway == true);
    private int BackNineFairwaysTotal => BackNineEntries.Count(e => e.Par > 3);
    private int TotalFairwaysHit => State.HoleEntries.Count(e => e.HitFairway == true);
    private int TotalFairwaysTotal => State.HoleEntries.Count(e => e.Par > 3);

    // GIR totals
    private int FrontNineGreensHit => FrontNineEntries.Count(e => e.HitGreen == true);
    private int BackNineGreensHit => BackNineEntries.Count(e => e.HitGreen == true);
    private int TotalGreensHit => State.HoleEntries.Count(e => e.HitGreen == true);

    // Event handlers
    private async Task OnBackClicked() => await OnBack.InvokeAsync();
    private async Task OnReviewClicked() => await OnReview.InvokeAsync();
    private async Task OnScanScorecardClicked() => await OnScanScorecard.InvokeAsync();

    // Shot tracking helpers
    private int FrontNineShotCount => FrontNineEntries.Where(e => e.Shots is { Count: > 0 }).Sum(e => e.Shots!.Count);
    private int BackNineShotCount => BackNineEntries.Where(e => e.Shots is { Count: > 0 }).Sum(e => e.Shots!.Count);
    private int TotalShotCount => State.HoleEntries.Where(e => e.Shots is { Count: > 0 }).Sum(e => e.Shots!.Count);

    private bool IsHoleComplete(HoleScoreEntry entry)
        => entry.Shots is { Count: > 0 } && entry.Shots[^1].EndDistance == null;

    private double GetHoleSg(HoleScoreEntry entry)
    {
        if (entry.Shots is not { Count: > 0 } || !IsHoleComplete(entry)) return 0;
        var score = entry.Shots.Count + entry.Shots.Sum(s => s.PenaltyStrokes);
        return StrokesGainedCalculator.CalculateHoleSg(entry.Shots, entry.Par, entry.HoleNumber, score).SgTotal;
    }

    private string FormatSgTotal(List<HoleScoreEntry> entries)
    {
        var completed = entries.Where(e => e.Shots is { Count: > 0 } && IsHoleComplete(e)).ToList();
        if (completed.Count == 0) return "-";
        var total = completed.Sum(e => GetHoleSg(e));
        return total.ToString("+0.00;-0.00");
    }

    private string GetShotsCellStyle(HoleScoreEntry entry)
    {
        return "cursor: pointer; font-weight: 600;";
    }

    private async Task OpenShotDialog(HoleScoreEntry entry, HoleInfo hole)
    {
        entry.Shots ??= new();

        var result = await DialogService.OpenAsync<ShotEntryDialog>(
            $"Hole {hole.HoleNumber} — Shots",
            new Dictionary<string, object>
            {
                { "HoleNumber", hole.HoleNumber },
                { "Par", hole.Par },
                { "Yardage", hole.Yardage },
                { "Shots", entry.Shots }
            },
            new DialogOptions
            {
                Width = "600px",
                CloseDialogOnOverlayClick = false,
                CloseDialogOnEsc = true
            });

        if (result is List<ShotData> updatedShots)
        {
            entry.Shots = updatedShots;
            if (entry.Shots.Count > 0 && IsHoleComplete(entry))
            {
                entry.Score = (short)(entry.Shots.Count + entry.Shots.Sum(s => s.PenaltyStrokes));
            }
        }
    }

    // Score/Putt input handlers
    private void OnScoreChanged(HoleScoreEntry entry, ChangeEventArgs e)
    {
        if (short.TryParse(e.Value?.ToString(), out var val) && val >= 1 && val <= 15)
        {
            entry.Score = val;
        }
    }

    private void OnPuttsChanged(HoleScoreEntry entry, ChangeEventArgs e)
    {
        var raw = e.Value?.ToString();
        if (string.IsNullOrWhiteSpace(raw))
        {
            entry.NumberOfPutts = null;
            return;
        }
        if (short.TryParse(raw, out var val) && val >= 0 && val <= 10)
        {
            entry.NumberOfPutts = val;
        }
    }

    private void OnApproachYardageChanged(HoleScoreEntry entry, ChangeEventArgs e)
    {
        var raw = e.Value?.ToString();
        if (string.IsNullOrWhiteSpace(raw))
        {
            entry.ApproachYardage = null;
            return;
        }
        if (int.TryParse(raw, out var val) && val >= 0 && val <= 600)
        {
            entry.ApproachYardage = val;
        }
    }

    // Toggle handlers
    private void ToggleFairway(HoleScoreEntry entry)
    {
        if (entry.Par <= 3) return;

        if (entry.HitFairway == null)
        {
            // unset -> hit
            entry.HitFairway = true;
            entry.MissFairwayType = null;
        }
        else if (entry.HitFairway == true)
        {
            // hit -> generic miss (MissOther = 999)
            entry.HitFairway = false;
            entry.MissFairwayType = (long)MissType.MissTypeEnum.MissOther;
        }
        else
        {
            // miss -> cycle: generic X -> Left -> Right -> Short -> Long -> unset
            var next = NextMissDirection(entry.MissFairwayType);
            if (next.HasValue)
            {
                entry.MissFairwayType = next.Value;
            }
            else
            {
                // Cycle ended, reset to unset
                entry.HitFairway = null;
                entry.MissFairwayType = null;
            }
        }
    }

    private void ToggleGir(HoleScoreEntry entry)
    {
        if (entry.HitGreen == null)
        {
            // unset -> hit
            entry.HitGreen = true;
            entry.MissGreenType = null;
        }
        else if (entry.HitGreen == true)
        {
            // hit -> generic miss (MissOther = 999)
            entry.HitGreen = false;
            entry.MissGreenType = (long)MissType.MissTypeEnum.MissOther;
        }
        else
        {
            // miss -> cycle: generic X -> Left -> Right -> Short -> Long -> unset
            var next = NextMissDirection(entry.MissGreenType);
            if (next.HasValue)
            {
                entry.MissGreenType = next.Value;
            }
            else
            {
                // Cycle ended, reset to unset
                entry.HitGreen = null;
                entry.MissGreenType = null;
            }
        }
    }

    /// <summary>
    /// Returns the next miss direction in the cycle, or null when the cycle is complete.
    /// Cycle: 999 (Other/generic X) -> 1 (Left) -> 2 (Right) -> 3 (Short) -> 4 (Long) -> end (null).
    /// </summary>
    private static long? NextMissDirection(long? current) => current switch
    {
        999 => 1,   // Other -> Left
        1 => 2,     // Left -> Right
        2 => 3,     // Right -> Short
        3 => 4,     // Short -> Long
        _ => null   // Long (or unknown) -> cycle ends
    };

    private static string GetMissIcon(long? missType) => missType switch
    {
        1 => "arrow_circle_left",   // Left
        2 => "arrow_circle_right",  // Right
        3 => "arrow_circle_down",   // Short
        4 => "arrow_circle_up",     // Long
        _ => "cancel"               // Generic miss
    };

    private string GetScoreInputStyle(HoleScoreEntry entry)
    {
        var diff = entry.Score - entry.Par;
        if (diff < 0) return "color: var(--rz-success); font-weight: 700;";
        if (diff == 0) return "font-weight: 600;";
        if (diff == 1) return "color: var(--rz-warning); font-weight: 700;";
        return "color: var(--rz-danger); font-weight: 700;";
    }
}
