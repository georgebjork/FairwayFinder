@page "/round/{RoundId:long}"
@rendermode InteractiveServer
@attribute [Authorize]
@using System.Security.Claims
@using FairwayFinder.Features.Data
@using FairwayFinder.Features.Services.Interfaces
@using FairwayFinder.Web.Components.Shared.Dialogs
@using FairwayFinder.Features.Enums
@using FairwayFinder.Web.Components.Pages.Rounds.Components
@using FairwayFinder.Web.Components.Shared.Layout.Breadcrumb
@inject IRoundService RoundService
@inject NavigationManager NavigationManager
@inject BreadcrumbState BreadcrumbState
@inject DialogService DialogService
@inject NotificationService NotificationService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IProfileService ProfileService
@inject IJSRuntime JSRuntime

<PageTitle>View Round</PageTitle>

@if (_loading)
{
    <RadzenStack AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Center" class="rz-p-8">
        <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
    </RadzenStack>
}
else if (_round is null)
{
    <RadzenCard class="rz-p-5">
        <RadzenAlert AlertStyle="AlertStyle.Warning" Shade="Shade.Lighter" AllowClose="false">
            Round not found.
        </RadzenAlert>
        <RadzenButton Text="Back to Home" Icon="arrow_back" ButtonStyle="ButtonStyle.Secondary" 
                      Click="@(() => NavigationManager.NavigateTo("/"))" class="rz-mt-4" />
    </RadzenCard>
}
else
{
    <RadzenStack Gap="1.5rem">
        <!-- Header -->
        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Start">
            <RadzenStack Gap="0.25rem">
                <RadzenText TextStyle="TextStyle.H3" class="rz-m-0">@_round.CourseName</RadzenText>
                <RadzenStack Orientation="Orientation.Horizontal" Gap="2rem">
                    <RadzenText TextStyle="TextStyle.Body2" style="color: var(--rz-text-secondary-color);">
                        Tee Box: @_round.Teebox.TeeboxName
                    </RadzenText>
                    <RadzenText TextStyle="TextStyle.Body2" style="color: var(--rz-text-secondary-color);">
                        Date: @_round.DatePlayed.ToString("M/d/yy")
                    </RadzenText>
                </RadzenStack>
            </RadzenStack>

            <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem">
                @if (_isPublic)
                {
                    <RadzenButton Text="Share" Icon="share"
                                  ButtonStyle="ButtonStyle.Light" Variant="Variant.Outlined"
                                  Click="CopyShareLink" />
                }
                <RadzenButton Text="Edit" Icon="edit"
                              ButtonStyle="ButtonStyle.Light" Variant="Variant.Outlined"
                              Click="@(() => NavigationManager.NavigateTo($"/round/{RoundId}/edit"))" />
                <RadzenButton Text="Delete" Icon="delete"
                              ButtonStyle="ButtonStyle.Danger" Variant="Variant.Outlined"
                              Click="OnDeleteRoundClicked" />
            </RadzenStack>
        </RadzenStack>
        
        
        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.Start">
            <!-- Scoring Breakdown Pills -->
            <RoundScoringPills Round="@_round" />
        </RadzenStack>

        <!-- Scorecard -->
        <FairwayFinderScorecard Round="@_round" />

        <!-- Round Stats -->
        <RoundStatsPanel Round="@_round" />

        
    </RadzenStack>
}

@code {
    [Parameter]
    public long RoundId { get; set; }

    private RoundResponse? _round;
    private bool _loading = true;
    private string _currentUserId = string.Empty;
    private bool _isPublic;
    private string _shareableUrl = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        _currentUserId = authState.User.FindFirstValue(ClaimTypes.NameIdentifier) ?? string.Empty;

        if (!string.IsNullOrEmpty(_currentUserId))
        {
            var profile = await ProfileService.GetOrCreateProfileAsync(_currentUserId);
            _isPublic = profile.IsPublic;
            if (_isPublic)
            {
                var baseUri = NavigationManager.BaseUri.TrimEnd('/');
                _shareableUrl = $"{baseUri}/profile/{profile.PublicIdentifier}/round/{RoundId}";
            }
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;
        _round = await RoundService.GetRoundByIdAsync(RoundId);
        _loading = false;

        if (_round is not null)
        {
            BreadcrumbState.Set(
                new BreadcrumbItem("Home", "/"),
                new BreadcrumbItem($"{_round.CourseName} - {_round.DatePlayed:M/d/yy}")
            );
        }
        else
        {
            BreadcrumbState.Set(
                new BreadcrumbItem("Home", "/"),
                new BreadcrumbItem("Round")
            );
        }
    }

    private async Task CopyShareLink()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", _shareableUrl);
            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Success,
                Summary = "Copied!",
                Detail = "Link copied to clipboard.",
                Duration = 2000
            });
        }
        catch
        {
            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Warning,
                Summary = "Copy Failed",
                Detail = "Please copy the link manually.",
                Duration = 3000
            });
        }
    }

    private async Task OnDeleteRoundClicked()
    {
        if (_round is null) return;

        var result = await DialogService.OpenAsync<DeleteConfirmDialog>("Delete Round",
            new Dictionary<string, object>
            {
                { "EntityName", $"{_round.CourseName} - {_round.DatePlayed:M/d/yy}" },
                { "WarningMessage", "This will also delete all scores and stats for this round." }
            },
            new DialogOptions
            {
                Width = "450px",
                CloseDialogOnOverlayClick = false,
                CloseDialogOnEsc = true
            });

        if (result is true)
        {
            try
            {
                var success = await RoundService.DeleteRoundAsync(RoundId, _currentUserId);
                if (success)
                {
                    NotificationService.Notify(new NotificationMessage
                    {
                        Severity = NotificationSeverity.Success,
                        Summary = "Round Deleted",
                        Detail = $"{_round.CourseName} - {_round.DatePlayed:M/d/yy} has been deleted.",
                        Duration = 4000
                    });
                    NavigationManager.NavigateTo("/");
                }
            }
            catch (Exception ex)
            {
                NotificationService.Notify(new NotificationMessage
                {
                    Severity = NotificationSeverity.Error,
                    Summary = "Failed to Delete Round",
                    Detail = ex.Message,
                    Duration = 6000
                });
            }
        }
    }
}
