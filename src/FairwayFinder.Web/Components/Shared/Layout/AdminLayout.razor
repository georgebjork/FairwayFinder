@using FairwayFinder.Web.Components.Shared.Layout.Breadcrumb
@using FairwayFinder.Web.Components.Shared.Wrappers
@inherits LayoutComponentBase

<RadzenComponents />

<RadzenDialog />
<RadzenContextMenu />
<RadzenNotification />

<RadzenLayout>
    <AppHeader OnToggleSidebar="ToggleSidebar" />

    <RadzenSidebar Responsive="true" @bind-Expanded="_sidebarExpanded">
        <RadzenPanelMenu>
            <RadzenPanelMenuItem Text="Overview" Icon="dashboard" Path="/admin" Match="NavLinkMatch.All" />
            <RadzenPanelMenuItem Text="Users" Icon="people" Path="/admin/users" />
            <RadzenPanelMenuItem Text="Rounds" Icon="sports_golf" Path="/admin/rounds" />
            <RadzenPanelMenuItem Text="Courses" Icon="golf_course" Path="/courses" />
            <RadzenPanelMenuItem Text="Invites" Icon="mail" Path="/admin/invites" />
            <RadzenPanelMenuItem Text="System" Icon="settings" Path="/admin/system" />
            <RadzenPanelMenuItem Text="Health" Icon="monitor_heart" Path="/admin/health" />
            <RadzenPanelMenuItem Text="Request Logs" Icon="receipt_long" Path="/admin/logs" />
        </RadzenPanelMenu>
    </RadzenSidebar>

    <RadzenBody>
        <Breadcrumb />
        <div class="rz-p-4">
            @Body
        </div>
    </RadzenBody>

    <AppFooter />
</RadzenLayout>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private bool _sidebarExpanded = true;

    private void ToggleSidebar() => _sidebarExpanded = !_sidebarExpanded;
}
