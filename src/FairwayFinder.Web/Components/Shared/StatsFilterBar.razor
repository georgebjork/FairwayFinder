<RadzenCard class="rz-p-3">
    <RadzenStack Orientation="Orientation.Horizontal" Gap="1rem" AlignItems="AlignItems.End" Wrap="FlexWrap.Wrap">
        @if (AdditionalFilters is not null)
        {
            @AdditionalFilters
        }

        <RadzenStack Gap="0.25rem">
            <RadzenText TextStyle="TextStyle.Caption" style="color: var(--rz-text-secondary-color);">From</RadzenText>
            <RadzenDatePicker TValue="DateOnly?"
                              Value="@StartDate"
                              DateFormat="MM/dd/yyyy"
                              AllowClear="true"
                              Placeholder="Start date"
                              Style="width: 160px;"
                              Change="@OnStartDateChanged" />
        </RadzenStack>

        <RadzenStack Gap="0.25rem">
            <RadzenText TextStyle="TextStyle.Caption" style="color: var(--rz-text-secondary-color);">To</RadzenText>
            <RadzenDatePicker TValue="DateOnly?"
                              Value="@EndDate"
                              DateFormat="MM/dd/yyyy"
                              AllowClear="true"
                              Placeholder="End date"
                              Style="width: 160px;"
                              Change="@OnEndDateChanged" />
        </RadzenStack>

        @if (HasActiveFilters)
        {
            <RadzenButton Text="Clear Filters"
                          ButtonStyle="ButtonStyle.Primary"
                          Variant="Variant.Filled"
                          Size="ButtonSize.Medium"
                          Icon="clear"
                          Click="@OnClearFilters" />
        }

        @if (TrailingContent is not null)
        {
            @TrailingContent
        }
    </RadzenStack>
</RadzenCard>

@code {
    [Parameter] public DateOnly? StartDate { get; set; }
    [Parameter] public EventCallback<DateOnly?> StartDateChanged { get; set; }

    [Parameter] public DateOnly? EndDate { get; set; }
    [Parameter] public EventCallback<DateOnly?> EndDateChanged { get; set; }

    [Parameter] public RenderFragment? AdditionalFilters { get; set; }
    [Parameter] public RenderFragment? TrailingContent { get; set; }

    [Parameter] public bool HasActiveFilters { get; set; }
    [Parameter] public EventCallback OnClearFilters { get; set; }

    [Parameter] public EventCallback OnFilterChanged { get; set; }

    private async Task OnStartDateChanged(DateTime? value)
    {
        var dateOnly = value.HasValue ? DateOnly.FromDateTime(value.Value) : (DateOnly?)null;
        await StartDateChanged.InvokeAsync(dateOnly);
        await OnFilterChanged.InvokeAsync();
    }

    private async Task OnEndDateChanged(DateTime? value)
    {
        var dateOnly = value.HasValue ? DateOnly.FromDateTime(value.Value) : (DateOnly?)null;
        await EndDateChanged.InvokeAsync(dateOnly);
        await OnFilterChanged.InvokeAsync();
    }
}
